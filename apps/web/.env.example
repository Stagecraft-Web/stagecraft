# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string. The schema search path must be set if using
# a non-default schema.
DATABASE_URL=postgresql://user:password@localhost:5432/stagecraft?schema=public

# ─── Authentication (NextAuth v5) ────────────────────────────────────────────
# Random secret used to sign/encrypt session tokens.
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Base URL of this application. Used to construct OAuth redirect URIs.
# In production, set to your public domain (e.g. https://app.stagecraft.io).
AUTH_URL=http://localhost:3000

# ─── GitHub OAuth ─────────────────────────────────────────────────────────────
# Create an OAuth App at https://github.com/settings/applications/new
# Required scopes: read:user  user:email  repo
# Callback URL: <AUTH_URL>/api/auth/callback/github
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# ─── Netlify OAuth ────────────────────────────────────────────────────────────
# Create an OAuth App at https://app.netlify.com/user/applications
# Callback URL: <AUTH_URL>/api/integrations/netlify/callback
NETLIFY_CLIENT_ID=
NETLIFY_CLIENT_SECRET=

# ─── Webhook Secrets ──────────────────────────────────────────────────────────
# Secret used to verify incoming webhook requests from GitHub.
# Set this value in your GitHub repository's webhook settings under
# "Secret". GitHub signs each request as:
#   X-Hub-Signature-256: sha256=<HMAC-SHA256 of body using this secret>
GITHUB_WEBHOOK_SECRET=

# Secret used to verify incoming webhook requests from Netlify.
# Append this token to your Netlify webhook URL:
#   https://<your-domain>/api/webhooks/netlify?token=<NETLIFY_WEBHOOK_SECRET>
# Alternatively, pass it as an Authorization header: Bearer <secret>
NETLIFY_WEBHOOK_SECRET=
