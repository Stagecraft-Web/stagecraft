# Database (local Docker — see docker-compose.yml)
DATABASE_URL="postgresql://stagecraft:stagecraft@localhost:5432/stagecraft?schema=public"

# NextAuth
AUTH_SECRET=$(security find-generic-password -a stagecraft -s AUTH_SECRET -w)
AUTH_URL="http://localhost:3000"

# Public URL of the platform — used when provisioning STAGECRAFT_PLATFORM_URL
# on artist sites so they can reach the broker. In dev, AUTH_URL is
# localhost (so NextAuth/OAuth work) but artist sites deploy to Vercel
# and can't reach localhost — point this at prod so /create from a local
# dashboard yields working artist sites. In prod, leave unset and
# AUTH_URL IS the public URL.
STAGECRAFT_PUBLIC_URL="https://stagecraft.website"

# GitHub OAuth
AUTH_GITHUB_ID="Ov23liS2UtLLa9jO3vXw"
AUTH_GITHUB_SECRET=$(security find-generic-password -a stagecraft -s AUTH_GITHUB_SECRET -w)

# State signing (install URLs, verification tokens)
STAGECRAFT_STATE_SIGNING_SECRET=$(security find-generic-password -a stagecraft -s STAGECRAFT_STATE_SIGNING_SECRET -w)

# Stagecraft GitHub App
GITHUB_APP_INSTALL_URL="https://github.com/apps/stagecraft-bot/installations/new"

# Netlify OAuth
NETLIFY_CLIENT_ID="axsTFDZbuBQM8vwp_oi3EbuSv1GV6kNOJM2gb9Ig-YM"
NETLIFY_CLIENT_SECRET=$(security find-generic-password -a stagecraft -s AUTH_NETLIFY_SECRET -w)

# GitHub App
GITHUB_APP_ID=3579008
GITHUB_APP_PRIVATE_KEY=$(security find-generic-password -a stagecraft -s STAGECRAFT_GITHUB_APP_PRIVATE_KEY -w)
