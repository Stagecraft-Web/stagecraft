---
/**
 * Astro wrapper around the shared React `FormGroup` primitive in
 * `src/components/react/FormGroup.tsx`. Astro server-renders the component
 * to plain HTML at build time (no React runtime ships to the client),
 * so `.astro` callers keep their HTML-native call site:
 *
 *   <FormGroup label="Name" name="name" type="text" isRequired />
 *
 * while React islands (e.g. the Appearance sidebar) consume the same
 * primitive directly. Single source of truth for the visual style; both
 * surfaces stay in lock-step.
 */
import FormGroupReact, {
  type FormGroupType,
} from "./react/FormGroup";

interface Props {
  label: string;
  name: string;
  type?: FormGroupType;
  rows?: number;
  selectOptions?: string[];
  isRequired?: boolean;
  autocomplete?: string;
  placeholder?: string;
}

const props = Astro.props;
---

<FormGroupReact {...props} />
