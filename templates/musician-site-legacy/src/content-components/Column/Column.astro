---
// Column — a single column within a Columns layout.
import type { TextAlignment } from "../_shared/types";

interface Props {
  textAlign?: TextAlignment;
}

const { textAlign = "start" } = Astro.props;
---

<div
  class:list={[
    "column",
    textAlign !== "start" && `column--align-${textAlign}`,
  ]}
>
  <slot />
</div>

<style>
  .column {
    min-width: 0;
  }

  .column--align-center {
    text-align: center;
  }

  .column--align-end {
    text-align: end;
  }

  /* Center block-level inline-flex children (buttons) when the column itself
     is centered. Scoped to the centered modifier so default columns are
     unaffected. */
  .column--align-center :global(.btn) {
    margin-inline: auto;
  }
</style>
