---
import { Image, getImage } from "astro:assets";
import { resolveImage } from "../../lib/resolve-image";
import { resolveVideo } from "../../lib/resolve-video";
import type { HeadingLevel, TextAlignment } from "../_shared/types";

interface Props {
  title?: string;
  headingLevel?: HeadingLevel;
  isTitleHidden?: boolean;
  /** Relative path to a background image in src/assets/images/ */
  image?: string;
  /**
   * Optional relative path to a background video in src/assets/videos/.
   * When set, the video autoplays/loops as the section background and the
   * `image` is used as the poster + fallback for browsers that block
   * autoplay or for users with `prefers-reduced-motion: reduce`.
   */
  video?: string;
  /**
   * Inline text alignment inside the overlay. Defaults to "start" so the
   * base `center`-aligned overlay behavior is preserved via a modifier class
   * that only kicks in when the author explicitly opts for a non-start value.
   */
  textAlign?: TextAlignment;
}

const {
  title,
  headingLevel = "h2",
  isTitleHidden = false,
  image,
  video,
  textAlign = "start",
} = Astro.props;
const Heading = headingLevel;
const resolvedImage = resolveImage(image);
const resolvedVideo = resolveVideo(video);
const hasVideo = resolvedVideo !== undefined;

// `<video poster>` only takes a URL — get a single processed image we can
// reuse as the poster string. Falling back to the resolved image src keeps
// the build cheap when no extra processing is configured.
let posterUrl: string | undefined;
if (hasVideo && resolvedImage) {
  const processed = await getImage({ src: resolvedImage });
  posterUrl = processed.src;
}
---

<section class="fullscreen-section">
  {resolvedImage ? (
    <Image
      src={resolvedImage}
      alt=""
      class:list={["fullscreen-bg", hasVideo && "fullscreen-bg--poster"]}
      loading="eager"
    />
  ) : (
    <div class="fullscreen-placeholder">
      <svg class="placeholder-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <rect x="3" y="3" width="18" height="18" rx="2" />
        <path d="M3 16l5-5 4 4 4-4 5 5" />
        <circle cx="8.5" cy="8.5" r="1.5" />
      </svg>
    </div>
  )}
  {hasVideo && (
    <video
      class="fullscreen-video"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      poster={posterUrl}
      aria-hidden="true"
    >
      <source src={resolvedVideo.src} type={resolvedVideo.type} />
    </video>
  )}
  <div class="fullscreen-overlay" />
  <div
    class:list={[
      "fullscreen-content container",
      textAlign !== "start" && `fullscreen-content--align-${textAlign}`,
    ]}
  >
    {title && (
      <Heading class:list={[isTitleHidden && "screenreader-only"]}>
        {title}
      </Heading>
    )}
    <slot />
  </div>
</section>

<style>
  .fullscreen-section {
    position: relative;
    /* Break out of the page container to span the full viewport width. */
    width: 100vw;
    margin-inline: calc(50% - 50vw);
    /* Always leave breathing room before the next content block. Adjacent
       plain-text siblings have no top margin of their own, so the space
       lives here rather than on siblings. */
    margin-block-end: 3rem;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  /* When FullscreenSection is the first child of a Markdoc-rendered page
     (wrapped in <article>), pull it up to absorb main's top padding so the
     hero flushes against the header. */
  :global(article) > .fullscreen-section:first-child {
    margin-top: calc(-1 * var(--page-pad-y));
  }

  .fullscreen-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  /* Background video covers the section the same way the image does and
     sits one z-layer above the poster image so it visually replaces it
     once playback starts. */
  .fullscreen-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
    /* Promote to its own compositor layer to avoid jank during scroll. */
    will-change: transform;
  }

  /* When a video is present the image is the poster/fallback only — keep
     it visible underneath so it shows during load and on autoplay-block. */
  .fullscreen-bg--poster {
    z-index: 0;
  }

  /* Reduced-motion users get the still poster image only. Hide the video
     element entirely so the browser doesn't even fetch the rest of it. */
  @media (prefers-reduced-motion: reduce) {
    .fullscreen-video {
      display: none;
    }
  }

  .fullscreen-placeholder {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-accent) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .placeholder-icon {
    width: 80px;
    height: 80px;
    opacity: 0.15;
    color: var(--color-white);
  }

  .fullscreen-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.4);
    z-index: 1;
  }

  .fullscreen-content {
    position: relative;
    z-index: 2;
    text-align: center;
    color: var(--color-white);
    padding-block: 4rem;
  }

  /* Overrides for the default text-align: center above. Only applied when
     the author explicitly picks a non-start alignment — keeps the default
     rendered output unchanged. */
  .fullscreen-content--align-center {
    text-align: center;
  }

  .fullscreen-content--align-end {
    text-align: end;
  }

  .fullscreen-content :global(h1),
  .fullscreen-content :global(h2),
  .fullscreen-content :global(h3),
  .fullscreen-content :global(h4) {
    color: var(--color-white);
  }

  .fullscreen-content :global(p) {
    color: var(--color-white);
    opacity: 0.9;
  }
</style>
