---
// Rename astro:assets' Image to AstroImage — our own component is Image.astro
// so the default import would shadow itself.
import { Image as AstroImage } from "astro:assets";
import { resolveImage } from "../../lib/resolve-image";

interface Props {
  src: string;
  alt: string;
}

const { src, alt } = Astro.props;
const resolved = resolveImage(src);
---

{resolved && (
  <AstroImage src={resolved} alt={alt} class="content-image" />
)}

<style>
  .content-image {
    width: 100%;
    height: auto;
    border-radius: var(--radius);
    display: block;
  }
</style>
