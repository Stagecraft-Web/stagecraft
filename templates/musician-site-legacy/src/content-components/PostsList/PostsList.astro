---
// Markdoc block — reads the `posts` collection and renders either a card
// grid (default) or a linear row list. Filtering, sorting, and limiting is
// delegated to the pure helper in src/lib/resolve-posts.ts so the logic
// stays unit-testable.
//
// Each post is a <Card href={postHref} hover> composition — the grid vs.
// list toggle just swaps Card's `orientation` and `mediaAspect`.
import { getCollection } from "astro:content";
import Card from "../Card/Card.astro";
import {
  resolvePosts,
  getPostHref,
  isPostExternal,
  type PostsListFilterCategory,
} from "../../lib/resolve-posts";
import type { PostsListLayout } from "./schema";

interface Props {
  limit?: number;
  category?: PostsListFilterCategory;
  layout?: PostsListLayout;
}

const { limit, category = "all", layout = "grid" } = Astro.props;

const entries = await getCollection("posts");
const posts = resolvePosts(entries, { limit, category });

// Parse YYYY-MM-DD as a local-time date so the rendered label matches what
// the author entered. `new Date("2024-09-01")` is parsed as UTC midnight and
// shifts a day earlier in negative-UTC time zones — using the numeric parts
// explicitly avoids that off-by-one.
const formatDate = (iso: string) => {
  const [y, m, d] = iso.split("-").map(Number);
  return new Date(y, m - 1, d).toLocaleDateString(undefined, {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
};

const orientation = layout === "list" ? "horizontal" : "vertical";
// Grid posts look best at 16:9 (widescreen blog thumbnails). In list mode
// the media is a fixed side column whose height is driven by content, so
// aspect is left auto (Card handles that by construction for horizontal).
const mediaAspect = layout === "list" ? "auto" : "16:9";
---

{posts.length > 0 && (
  <ul class:list={["posts-list", `posts-list--${layout}`]} role="list">
    {posts.map((post) => {
      const href = getPostHref(post);
      const isExternal = isPostExternal(post);
      return (
        <li class="posts-list-item">
          <Card
            href={href}
            isExternal={isExternal}
            eyebrow={post.data.category}
            title={post.data.title}
            meta={formatDate(post.data.publishedDate)}
            media={post.data.featuredImage?.src}
            mediaAlt={post.data.featuredImage?.alt}
            mediaAspect={mediaAspect}
            orientation={orientation}
            variant="filled"
            hover
          >
            {post.data.excerpt && <p class="posts-list-excerpt">{post.data.excerpt}</p>}
          </Card>
        </li>
      );
    })}
  </ul>
)}

<style>
  .posts-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.5rem;
  }

  .posts-list--grid {
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 280px), 1fr));
  }

  .posts-list--list {
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  .posts-list-item {
    margin: 0;
  }

  /* Card handles its own hover effect; we just make sure the card fills the
     list item so clicks land anywhere inside the tile. */
  .posts-list-item :global(.card) {
    height: 100%;
  }

  .posts-list-excerpt {
    margin: 0;
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
    line-height: 1.5;
  }
</style>
