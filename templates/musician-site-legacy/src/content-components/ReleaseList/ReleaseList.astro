---
// Markdoc block — reads the `releases` collection and renders a grid of
// release cards (cover art + title + type + date + description + streaming
// links). Each card is a <Card> composition; this file owns the collection
// loading, the link-platform ordering, and the surrounding grid layout, but
// the per-item shape is delegated to the shared Card primitive.
import { getCollection } from "astro:content";
import Card from "../Card/Card.astro";
import Button from "../Button/Button.astro";

const releaseEntries = await getCollection("releases");
const releases = releaseEntries.map((e) => e.data);
---

{releases.length > 0 && (
  <div class="release-grid grid grid-2">
    {releases.map((release) => {
      const streamLinks = Object.entries(release.links ?? {}).filter(
        ([, url]) => url,
      );
      return (
        <Card
          title={release.title}
          meta={`${release.type.toUpperCase()} · ${release.releaseDate}`}
          media={release.coverImage.src}
          mediaAlt={release.coverImage.alt}
          mediaAspect="1:1"
          variant="filled"
        >
          {release.description && (
            <p class="release-card-desc">{release.description}</p>
          )}
          {streamLinks.length > 0 && (
            <div class="release-card-links" slot="footer">
              {streamLinks.map(([platform, url]) => (
                <Button
                  href={url}
                  variant="outline"
                  isExternal
                  class="release-card-link-btn"
                  label={platform}
                />
              ))}
            </div>
          )}
        </Card>
      );
    })}
  </div>
)}

<style>
  /* Preserve the two-column grid sizing ReleaseList has always had. Card
     handles the per-item look. */
  .release-grid.grid-2 {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 280px), 1fr));
    gap: 1.5rem;
  }

  .release-card-desc {
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
  }

  .release-card-links {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  /* Compact buttons inside a card footer — mirrors the pre-refactor
     release-link-btn sizing. */
  .release-card-links :global(.btn) {
    font-size: var(--font-size-xs);
    padding: 0.5rem 1rem;
    text-transform: capitalize;
  }
</style>
