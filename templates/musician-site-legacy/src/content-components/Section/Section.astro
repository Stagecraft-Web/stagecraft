---
import type { HeadingLevel, TextAlignment } from "../_shared/types";

interface Props {
  title?: string;
  headingLevel?: HeadingLevel;
  isTitleHidden?: boolean;
  textAlign?: TextAlignment;
}

const {
  title,
  headingLevel = "h2",
  isTitleHidden = false,
  textAlign = "start",
} = Astro.props;
const Heading = headingLevel;
---

<section
  class:list={[
    "section",
    textAlign !== "start" && `section--align-${textAlign}`,
  ]}
>
  {title && (
    <Heading class:list={[isTitleHidden && "screenreader-only"]}>
      {title}
    </Heading>
  )}
  <slot />
</section>

<style>
  .section--align-center {
    text-align: center;
  }

  .section--align-end {
    text-align: end;
  }

  /* Center block-level children (buttons, centered blocks) when the section
     itself is centered. `text-align: center` handles inline content; this
     handles inline-flex button blocks and scoped utility elements. */
  .section--align-center :global(.btn) {
    margin-inline: auto;
  }
</style>
