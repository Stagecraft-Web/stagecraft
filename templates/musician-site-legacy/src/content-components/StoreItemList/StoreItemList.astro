---
// Markdoc block — reads the `storeItems` collection and renders a grid or
// list of buyable cards. Each card carries a cover image, title, format
// badge, price, optional description, and a "Buy" button that opens the
// external storefront in a new tab.
//
// Filter defaults to "available" — sold-out items are hidden by default so
// authors don't have to manually curate when inventory runs out. Setting
// filter="all" shows sold-out items with a grayscale overlay + badge.
import { Image } from "astro:assets";
import { getCollection, type CollectionEntry } from "astro:content";
import Button from "../Button/Button.astro";
import type {
  StoreItemFormat,
  StoreItemListFilter,
  StoreItemListLayout,
} from "../../lib/schemas";

interface Props {
  filter?: StoreItemListFilter;
  layout?: StoreItemListLayout;
}

const { filter = "available", layout = "grid" } = Astro.props;

// Use the collection-entry type directly — astro:content resolves
// `image.src` to Astro's ImageMetadata (the bundled image object with
// width/height), not the plain string in src/lib/schemas.ts.
type StoreItemEntry = CollectionEntry<"storeItems">["data"];

const storeItemEntries = await getCollection("storeItems");
const allItems: StoreItemEntry[] = storeItemEntries.map((e) => e.data);

// Apply filter:
//   - "all"        — every item, including sold-out
//   - "available"  — available + preorder (anything still buyable)
//   - "preorder"   — preorders only (for launch/announcement pages)
const visibleItems = allItems.filter((item) => {
  if (filter === "all") return true;
  if (filter === "preorder") return item.status === "preorder";
  return item.status !== "sold-out";
});

// Sort: explicit `order` first (ascending), then title. Items without `order`
// sink to the end, sorted alphabetically.
visibleItems.sort((a, b) => {
  const aHasOrder = typeof a.order === "number";
  const bHasOrder = typeof b.order === "number";
  if (aHasOrder && bHasOrder) {
    return (a.order as number) - (b.order as number);
  }
  if (aHasOrder) return -1;
  if (bHasOrder) return 1;
  return a.title.localeCompare(b.title);
});

const hasItems = visibleItems.length > 0;

// Human-friendly label for the format badge. With only 4 values, the label
// is just the capitalized format name.
const FORMAT_LABELS: Record<StoreItemFormat, string> = {
  album: "Album",
  ep: "EP",
  single: "Single",
  merch: "Merch",
};

// Format → CSS variable family. Each format gets its own scoped palette hook
// so sites can override per-format (`--color-format-album`, etc.) via their
// global.css if they want a distinct color story. The default mapping
// reuses existing site tokens.
type FormatFamily = StoreItemFormat;
function formatFamily(format: StoreItemFormat): FormatFamily {
  return format;
}

// Format the numeric price + ISO 4217 currency code into a locale-aware
// display string via Intl.NumberFormat. Falls back to a plain "<amount>
// <currency>" string if the Intl formatter rejects the currency code (e.g.
// a 3-char code not in the CLDR catalog).
function formatPrice(amount: number, currency: string): string {
  try {
    return new Intl.NumberFormat(undefined, { style: "currency", currency }).format(amount);
  } catch {
    return `${amount.toFixed(2)} ${currency}`;
  }
}
---

{hasItems ? (
  <ul class:list={["store-items", `is-layout-${layout}`]}>
    {visibleItems.map((item) => {
      const isSoldOut = item.status === "sold-out";
      const isPreorder = item.status === "preorder";
      const family = formatFamily(item.format);
      return (
        <li
          class:list={[
            "store-item",
            `is-format-family-${family}`,
            { "is-sold-out": isSoldOut, "is-preorder": isPreorder },
          ]}
        >
          <div class="store-item-media">
            {item.image ? (
              <Image
                src={item.image.src}
                alt={item.image.alt}
                class="store-item-image"
              />
            ) : (
              <div class="store-item-image-placeholder" aria-hidden="true" />
            )}
            {isSoldOut && <span class="store-item-badge is-sold-out-badge">Sold Out</span>}
            {isPreorder && <span class="store-item-badge is-preorder-badge">Preorder</span>}
          </div>
          <div class="store-item-body">
            <span class="store-item-format">{FORMAT_LABELS[item.format]}</span>
            <h3 class="store-item-title">{item.title}</h3>
            <div class="store-item-price">{formatPrice(item.price, item.currency)}</div>
            {item.description && (
              <p class="store-item-description">{item.description}</p>
            )}
            <div class="store-item-action">
              {isSoldOut ? (
                <span class="store-item-soldout-text">Sold out</span>
              ) : (
                <Button
                  href={item.buyUrl}
                  variant="primary"
                  isExternal
                  label={isPreorder ? "Preorder" : "Buy"}
                />
              )}
            </div>
          </div>
        </li>
      );
    })}
  </ul>
) : (
  <p class="store-items-empty">No items available right now. Check back soon.</p>
)}

<style>
  .store-items {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .store-items.is-layout-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 240px), 1fr));
    gap: 1.5rem;
  }

  .store-items.is-layout-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .store-item {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
    display: flex;
  }

  .store-items.is-layout-grid .store-item {
    flex-direction: column;
  }

  .store-items.is-layout-list .store-item {
    flex-direction: row;
    align-items: stretch;
  }

  .store-item.is-sold-out {
    opacity: 0.85;
  }

  .store-item-media {
    position: relative;
    background: var(--color-surface);
  }

  .store-items.is-layout-grid .store-item-media {
    aspect-ratio: 1 / 1;
  }

  .store-items.is-layout-list .store-item-media {
    flex: 0 0 auto;
    width: 7.5rem;
    aspect-ratio: 1 / 1;
  }

  .store-item-image,
  .store-item-image-placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .store-item-image-placeholder {
    background: repeating-linear-gradient(
      45deg,
      var(--color-surface),
      var(--color-surface) 10px,
      var(--color-background) 10px,
      var(--color-background) 20px
    );
  }

  .store-item.is-sold-out .store-item-image,
  .store-item.is-sold-out .store-item-image-placeholder {
    filter: grayscale(1);
  }

  .store-item-badge {
    position: absolute;
    top: 0.5rem;
    left: 0.5rem;
    display: inline-block;
    padding: 0.25rem 0.625rem;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: var(--radius);
  }

  .store-item-badge.is-sold-out-badge {
    background: var(--color-text-muted);
    color: var(--color-surface);
  }

  .store-item-badge.is-preorder-badge {
    background: var(--color-accent);
    color: var(--color-surface);
  }

  .store-item-body {
    padding: 1rem 1.25rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  /*
   * Format-family badge colors. Default mapping uses existing site tokens
   * so no new CSS variables are required — an artist's accent/secondary
   * palette drives the color story. Sites that want distinct per-family
   * swatches can override --color-format-* in their own global.css.
   */
  .store-item-format {
    display: inline-block;
    align-self: flex-start;
    padding: 0.1875rem 0.5rem;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: var(--radius);
    background: var(--color-format-bg, var(--color-background));
    color: var(--color-format-text, var(--color-text-muted));
    border: 1px solid var(--color-format-border, var(--color-border));
  }

  .store-item.is-format-family-album {
    --color-format-bg: var(--color-surface);
    --color-format-text: var(--color-primary);
    --color-format-border: var(--color-primary);
  }

  .store-item.is-format-family-ep {
    --color-format-bg: var(--color-surface);
    --color-format-text: var(--color-accent);
    --color-format-border: var(--color-accent);
  }

  .store-item.is-format-family-single {
    --color-format-bg: var(--color-surface);
    --color-format-text: var(--color-secondary);
    --color-format-border: var(--color-secondary);
  }

  .store-item.is-format-family-merch {
    --color-format-bg: var(--color-surface);
    --color-format-text: var(--color-text-muted);
    --color-format-border: var(--color-text-muted);
  }

  .store-item-title {
    margin: 0;
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text);
    line-height: 1.2;
  }

  .store-item-price {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-semibold);
    color: var(--color-primary);
  }

  .store-item-description {
    margin: 0;
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
  }

  .store-item-action {
    margin-top: auto;
    padding-top: 0.5rem;
  }

  .store-item-soldout-text {
    display: inline-block;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .store-items-empty {
    color: var(--color-text-muted);
    font-style: italic;
  }

  @media (max-width: 600px) {
    .store-items.is-layout-list .store-item {
      flex-direction: column;
    }
    .store-items.is-layout-list .store-item-media {
      width: 100%;
      aspect-ratio: 16 / 9;
    }
  }
</style>
