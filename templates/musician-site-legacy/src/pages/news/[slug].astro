---
// Per-post detail route.
//
// Renders at /news/<slug>. Only posts with status="published" generate
// routes; drafts become 404s in a production build but remain visible in
// `astro dev` so authors can preview work-in-progress.
//
// The slug strips a trailing `.mdoc` defensively — Astro's glob loader
// currently normalizes the id without the extension, but stripping here
// protects against upstream changes in that behaviour.
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("posts", (p) => p.data.status === "published");
  return posts.map((post) => ({
    params: { slug: post.id.replace(/\.mdoc$/, "") },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Parse YYYY-MM-DD as local time so the rendered label matches what the
// author entered — see PostsList.astro for the same off-by-one reasoning.
const [_y, _m, _d] = post.data.publishedDate.split("-").map(Number);
const publishedLabel = new Date(_y!, _m! - 1, _d!).toLocaleDateString(undefined, {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout title={post.data.title} description={post.data.excerpt}>
  <article class="post">
    <header class="post-header">
      <p class="post-category">{post.data.category}</p>
      <h1 class="post-title">{post.data.title}</h1>
      <time class="post-date" datetime={post.data.publishedDate}>
        {publishedLabel}
      </time>
    </header>

    {post.data.featuredImage && (
      <figure class="post-featured-image">
        <Image
          src={post.data.featuredImage.src}
          alt={post.data.featuredImage.alt}
        />
        {(post.data.featuredImage.caption || post.data.featuredImage.credit) && (
          <figcaption>
            {post.data.featuredImage.caption}
            {post.data.featuredImage.caption && post.data.featuredImage.credit && " — "}
            {post.data.featuredImage.credit}
          </figcaption>
        )}
      </figure>
    )}

    <div class="post-body">
      <Content />
    </div>

    {post.data.externalUrl && (
      <p class="post-external">
        <a href={post.data.externalUrl} target="_blank" rel="noopener noreferrer">
          Read the original →
        </a>
      </p>
    )}
  </article>
</BaseLayout>

<style>
  .post {
    max-width: var(--max-text-width, 720px);
    margin: 0 auto;
    padding: 3rem 1.5rem;
  }

  .post-header {
    margin-bottom: 2rem;
  }

  .post-category {
    font-size: var(--font-size-sm);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-secondary);
    font-weight: var(--font-weight-semibold);
    margin: 0 0 0.5rem;
  }

  .post-title {
    margin: 0 0 0.75rem;
  }

  .post-date {
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
  }

  .post-featured-image {
    margin: 0 0 2rem;
  }

  .post-featured-image img {
    width: 100%;
    height: auto;
    border-radius: var(--radius);
    display: block;
  }

  .post-featured-image figcaption {
    margin-top: 0.5rem;
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    font-style: italic;
  }

  .post-body {
    line-height: var(--line-height-loose, 1.7);
  }

  .post-external {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }
</style>
