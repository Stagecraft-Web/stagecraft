# Magic-link auth (ADR-007 §4)
# Required: random string ≥32 bytes. Generate with: openssl rand -hex 32
MAGIC_LINK_SIGNING_SECRET=

# Required: single allowed email for the editor (case-insensitive)
ADMIN_EMAIL=

# Resend — required for production magic-link delivery. The platform's
# /create flow auto-provisions both vars per-site from the artist's own
# Resend account (configured at /settings → Connect Resend on the
# platform). Locally, leave them unset and magic links print to the dev
# server console.
# RESEND_API_KEY=
# MAGIC_LINK_FROM=noreply@your-verified-domain.com
