# Magic-link auth (ADR-007 §4)
# Required: random string ≥32 bytes. Generate with: openssl rand -hex 32
MAGIC_LINK_SIGNING_SECRET=

# Required: single allowed email for the editor (case-insensitive)
ADMIN_EMAIL=

# Production-only — auto-provisioned by the platform's /create flow.
# When all three are set, magic-link emails are sent via the platform's
# shared Resend account (POST $STAGECRAFT_PLATFORM_URL/api/broker/send-email);
# when any is unset, magic links log to the dev server console instead.
# STAGECRAFT_PLATFORM_URL=
# STAGECRAFT_SITE_ID=
# STAGECRAFT_BROKER_SECRET=
