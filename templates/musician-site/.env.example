# Magic-link auth (ADR-007 §4)
# Required: random string ≥32 bytes. Generate with: openssl rand -hex 32
MAGIC_LINK_SIGNING_SECRET=

# Required: single allowed email for the editor (case-insensitive)
ADMIN_EMAIL=

# Optional in dev: when unset, magic links log to the dev server console.
# Required in production for actual email delivery via Resend.
RESEND_API_KEY=

# Optional: sender address for magic-link emails. Defaults to noreply@example.com
# MAGIC_LINK_FROM=noreply@your-domain.com
