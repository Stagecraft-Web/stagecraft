{
  // -------------------------------------------------------------------------
  // Markdoc language server (Stripe.markdoc-language-support).
  //
  // Gives us syntax highlighting, bracket matching inside `{% ... %}` tags,
  // tag-name completion, attribute completion, and attribute validation for
  // `.mdoc` files in the editor.
  //
  // The extension reads `markdoc.config.json` at the workspace root, which
  // points at `.markdoc/schema.generated.mjs`. Both files are generated by
  // `scripts/sync-markdoc-config.ts` from each component's schema.ts
  // (`src/content-components/<Name>/schema.ts`). The script runs:
  //
  //   - automatically on `npm run dev` (via `predev`)
  //   - manually with `npm run sync:markdoc-config`
  //   - in CI / `npm run validate` with `check:markdoc-config` (drift = fail)
  //
  // If you add or edit a schema and the editor doesn't pick up completions,
  // re-run `npm run sync:markdoc-config` — the extension auto-reloads
  // (`schema.watch: true` in markdoc.config.json).
  // -------------------------------------------------------------------------
  "files.associations": {
    "*.mdoc": "markdoc"
  }
}
