{
  "name": "musician-site",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "predev": "npm run sync:markdoc-config",
    "dev": "astro dev",
    "build": "astro check && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint .",
    "typecheck": "astro check",
    "test:smoke": "playwright test",
    "validate:content": "tsx scripts/validate-content.ts",
    "sync:markdoc-config": "tsx scripts/sync-markdoc-config.ts",
    "check:markdoc-config": "tsx scripts/sync-markdoc-config.ts --check",
    "test": "vitest run",
    "validate": "npm run validate:content && npm run check:markdoc-config && npm run lint && npm run typecheck && npm run build"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.0",
    "@astrojs/markdoc": "^1.0.3",
    "@astrojs/netlify": "^7.0.3",
    "@astrojs/react": "^4.2.0",
    "@keystatic/core": "^0.5.50",
    "astro": "^6.1.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^4.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.49.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-astro": "^1.3.0",
    "globals": "^15.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.3"
  }
}
