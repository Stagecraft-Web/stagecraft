---
import FormGroup from "./FormGroup.astro";
import Button from "./Button.astro";
---

<form class="contact-form" method="POST" action="/api/contact">
  <!-- Honeypot for spam prevention -->
  <div class="screenreader-only" aria-hidden="true">
    <label for="website">Website</label>
    <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
  </div>

  <FormGroup label="Name" name="name" isRequired />
  <FormGroup label="Email" name="email" type="email" isRequired />
  <FormGroup label="Subject" name="subject" />
  <FormGroup label="Message" name="message" isTextarea rows={5} isRequired />

  <Button type="submit" variant="primary">Send Message</Button>
</form>

<style>
  .contact-form {
    max-width: var(--max-text);
  }
</style>
