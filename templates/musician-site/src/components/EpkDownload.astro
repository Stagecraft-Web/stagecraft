---
import Button from "./Button.astro";

interface Props {
  path: string;
  label?: string;
}

const { path, label = "Download EPK" } = Astro.props;
---

<div class="epk-download">
  <Button href={path} variant="outline">{label}</Button>
</div>

<style>
  .epk-download {
    margin-block: 2rem;
  }
</style>
