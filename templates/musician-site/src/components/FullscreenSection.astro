---
import { Image } from "astro:assets";
import { resolveImage } from "../lib/resolve-image";

interface Props {
  title?: string;
  headingLevel?: "h1" | "h2" | "h3" | "h4";
  isTitleHidden?: boolean;
  /** Relative path to a background image in src/assets/images/ */
  image?: string;
}

const { title, headingLevel = "h2", isTitleHidden = false, image } = Astro.props;
const Heading = headingLevel;
const resolved = resolveImage(image);
---

<section class="fullscreen-section">
  {resolved ? (
    <Image src={resolved} alt="" class="fullscreen-bg" loading="eager" />
  ) : (
    <div class="fullscreen-placeholder">
      <svg class="placeholder-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <rect x="3" y="3" width="18" height="18" rx="2" />
        <path d="M3 16l5-5 4 4 4-4 5 5" />
        <circle cx="8.5" cy="8.5" r="1.5" />
      </svg>
    </div>
  )}
  <div class="fullscreen-overlay" />
  <div class="fullscreen-content container">
    {title && (
      <Heading class:list={[isTitleHidden && "screenreader-only"]}>
        {title}
      </Heading>
    )}
    <slot />
  </div>
</section>

<style>
  .fullscreen-section {
    position: relative;
    /* Break out of the page container to span the full viewport width. */
    width: 100vw;
    margin-inline: calc(50% - 50vw);
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .fullscreen-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .fullscreen-placeholder {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-accent) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .placeholder-icon {
    width: 80px;
    height: 80px;
    opacity: 0.15;
    color: var(--color-white);
  }

  .fullscreen-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.4);
    z-index: 1;
  }

  .fullscreen-content {
    position: relative;
    z-index: 2;
    text-align: center;
    color: var(--color-white);
    padding-block: 4rem;
  }

  .fullscreen-content :global(h1),
  .fullscreen-content :global(h2),
  .fullscreen-content :global(h3),
  .fullscreen-content :global(h4) {
    color: var(--color-white);
  }

  .fullscreen-content :global(p) {
    color: var(--color-white);
    opacity: 0.9;
  }
</style>
