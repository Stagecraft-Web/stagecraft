---
import { Image } from "astro:assets";
import { buildNav, getSiteConfig } from "../lib/content";
import { resolveImage } from "../lib/resolve-image";

const nav = await buildNav();
const site = getSiteConfig();
const currentPath = Astro.url.pathname;

// Resolve the wordmark image path (e.g. "../../assets/images/wordmark.svg")
// into an Astro ImageMetadata object so Astro's <Image> can optimise it.
// If the author hasn't set a wordmark, or the file no longer exists, we
// fall through to the artist-name text below — safe default.
const wordmarkImage = site.wordmark ? resolveImage(site.wordmark.src) : undefined;
const hasWordmark = Boolean(site.wordmark && wordmarkImage);
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="site-logo" aria-label={site.artistName}>
      {hasWordmark && site.wordmark && wordmarkImage ? (
        <Image
          src={wordmarkImage}
          alt={site.wordmark.alt}
          class="site-wordmark"
          height={40}
          widths={[40, 80]}
        />
      ) : (
        <span class="site-title">{site.artistName}</span>
      )}
    </a>
    <button class="nav-toggle" aria-label="Toggle navigation" aria-expanded="false">
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
    </button>
    <nav class="main-nav" aria-label="Main navigation">
      <ul>
        {nav.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={[{ active: currentPath === item.href || (item.href !== "/" && currentPath.startsWith(item.href)) }]}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<script>
  // Astro scripts in .astro files are hoisted and run as standard deferred
  // scripts, so the DOM is ready when this executes.
  const toggle = document.querySelector(".nav-toggle");
  const nav = document.querySelector(".main-nav");

  toggle?.addEventListener("click", () => {
    const expanded = toggle.getAttribute("aria-expanded") === "true";
    toggle.setAttribute("aria-expanded", String(!expanded));
    nav?.classList.toggle("open");
  });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: 1rem;
  }

  .site-logo {
    display: inline-flex;
    align-items: center;
    color: var(--color-primary);
    text-decoration: none;
  }

  .site-title {
    font-family: var(--font-heading);
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-bold);
  }

  /* Wordmark renders at a fixed max-height so authored logos (which vary
     wildly in native dimensions) slot into the header at a predictable
     size regardless of the source file. Width is auto so the aspect ratio
     is preserved. */
  .site-wordmark {
    max-height: 2.25rem;
    width: auto;
    display: block;
  }

  .main-nav ul {
    display: flex;
    gap: 1.5rem;
    list-style: none;
  }

  .main-nav a {
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    text-decoration: none;
    transition: color 0.15s;
  }

  .main-nav a:hover,
  .main-nav a.active {
    color: var(--color-secondary);
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 4px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .nav-toggle-bar {
    width: 24px;
    height: 2px;
    background: var(--color-primary);
    transition: transform 0.2s;
  }

  /* --breakpoint-md (768px) */
  @media (max-width: 768px) {
    .nav-toggle {
      display: flex;
    }

    .main-nav {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--color-surface);
      border-bottom: 1px solid var(--color-border);
      padding: 1rem 1.5rem;
    }

    .main-nav.open {
      display: block;
    }

    .main-nav ul {
      flex-direction: column;
      gap: 0.75rem;
    }
  }
</style>
