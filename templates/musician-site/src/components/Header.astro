---
import { Image } from "astro:assets";
import { buildNav, getHomeHref, getHeaderAndNavConfig, getSiteConfig } from "../lib/content";
import { resolveImage } from "../lib/resolve-image";

const nav = await buildNav();
const site = getSiteConfig();
const headerConfig = getHeaderAndNavConfig();
const currentPath = Astro.url.pathname;

// Resolve the wordmark image path (e.g. "../../assets/images/wordmark.svg")
// into an Astro ImageMetadata object so Astro's <Image> can optimise it.
// If the author hasn't set a wordmark, or the file no longer exists, we
// fall through to the artist-name text below — safe default.
const wordmarkImage = headerConfig.wordmark ? resolveImage(headerConfig.wordmark.src) : undefined;
const hasWordmark = Boolean(headerConfig.wordmark && wordmarkImage);

// Logo targets the real home, not the splash page (which is meant to be
// seen once on first visit — returning visitors shouldn't land on it again
// when they click the logo).
const homeHref = await getHomeHref();

// Header style / position come from the Header & Navigation singleton.
// Both have Zod defaults so they're always present at runtime.
const isTransparent = headerConfig.headerStyle === "transparent";
const headerPosition = headerConfig.headerPosition;
const headerForegroundColor = headerConfig.headerForegroundColor?.trim() ?? "";
const hasHeaderForeground = isTransparent && headerForegroundColor.length > 0;

// When an author supplies a foreground color, expose it as a custom
// property so the nav-link / title CSS picks it up via var(--header-fg).
// Keystatic stores an empty string when the field is blank; don't emit the
// inline style in that case so the CSS fallback (muted/primary tokens)
// wins.
const headerStyle = hasHeaderForeground
  ? `--header-fg: ${headerForegroundColor};`
  : undefined;

const headerClasses = [
  "site-header",
  `site-header--position-${headerPosition}`,
  isTransparent ? "site-header--transparent" : null,
];
---

<header class:list={headerClasses} style={headerStyle}>
  <div class="container header-inner">
    <a href={homeHref} class="site-logo" aria-label={site.artistName}>
      {hasWordmark && headerConfig.wordmark && wordmarkImage ? (
        <Image
          src={wordmarkImage}
          alt={headerConfig.wordmark.alt}
          class="site-wordmark"
          height={40}
          widths={[40, 80]}
        />
      ) : (
        <span class="site-title">{site.artistName}</span>
      )}
    </a>
    <button class="nav-toggle" aria-label="Toggle navigation" aria-expanded="false">
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
    </button>
    <nav class="main-nav" aria-label="Main navigation">
      <ul>
        {nav.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={[{ active: currentPath === item.href || (item.href !== "/" && currentPath.startsWith(item.href)) }]}
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<script>
  // Astro scripts in .astro files are hoisted and run as standard deferred
  // scripts, so the DOM is ready when this executes.
  const toggle = document.querySelector(".nav-toggle");
  const nav = document.querySelector(".main-nav");

  toggle?.addEventListener("click", () => {
    const expanded = toggle.getAttribute("aria-expanded") === "true";
    toggle.setAttribute("aria-expanded", String(!expanded));
    nav?.classList.toggle("open");
  });

  // Scroll-state toggle — when the user scrolls past ~8px, we tag the
  // header with `is-scrolled` so CSS can fade in a surface background +
  // border. Only meaningful for sticky headers: a static header scrolls
  // away with the page, so giving it a background as the page scrolls
  // would briefly paint the still-visible top of the header before it
  // leaves the viewport. Skip the listener entirely when static.
  const header = document.querySelector(".site-header");
  if (header && header.classList.contains("site-header--position-sticky")) {
    const SCROLL_THRESHOLD = 8;
    const updateScrollState = () => {
      if (window.scrollY > SCROLL_THRESHOLD) {
        header.classList.add("is-scrolled");
      } else {
        header.classList.remove("is-scrolled");
      }
    };
    // passive: true because we're only reading scrollY, never calling
    // preventDefault — tells the browser it can paint without waiting.
    window.addEventListener("scroll", updateScrollState, { passive: true });
    updateScrollState();
  }
</script>

<style>
  .site-header {
    top: 0;
    z-index: 100;
    background: var(--color-surface);
    border-bottom: 1px solid var(--color-border);
    /* Border fades smoothly. Background does NOT transition: a fade-in
       would briefly let scrolling content (e.g. a dark hero image)
       read through the partially-transparent surface and create a
       visible flash. Filling instantly avoids the flash; the border
       transition is enough to keep the change from feeling abrupt. */
    transition: border-color 150ms ease-out;
  }

  /* Position modifiers — mutually exclusive. "static" is the CSS default
     (no explicit `position`) but we set it anyway for symmetry and to
     override any upstream rule. */
  .site-header--position-static {
    position: static;
  }

  .site-header--position-sticky {
    position: sticky;
  }

  /* Transparent modifier — drop the surface paint + border so the page
     background (typically a hero image) reads through. The scroll-state
     class restores the surface look once the user scrolls. */
  .site-header--transparent {
    background: transparent;
    border-bottom-color: transparent;
  }

  .site-header--transparent.is-scrolled {
    background: var(--color-surface);
    border-bottom-color: var(--color-border);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-block: 1rem;
  }

  .site-logo {
    display: inline-flex;
    align-items: center;
    color: var(--color-primary);
    text-decoration: none;
  }

  .site-title {
    font-family: var(--font-heading);
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-bold);
  }

  /* Wordmark renders at a fixed max-height so authored logos (which vary
     wildly in native dimensions) slot into the header at a predictable
     size regardless of the source file. Width is auto so the aspect ratio
     is preserved. */
  .site-wordmark {
    max-height: 2.25rem;
    width: auto;
    display: block;
  }

  .main-nav ul {
    display: flex;
    gap: 1.5rem;
    list-style: none;
  }

  .main-nav a {
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    text-decoration: none;
    transition: color 0.15s;
  }

  .main-nav a:hover,
  .main-nav a.active {
    color: var(--color-secondary);
  }

  /* When a transparent header has a `--header-fg` custom property set
     (from headerConfig.headerForegroundColor), prefer it for the title + nav
     links. Falls back to the usual tokens so sites without a custom
     color keep current behavior. Once the user scrolls (is-scrolled),
     the surface comes back and we restore the regular tokens so link
     contrast against the surface is preserved. */
  .site-header--transparent .site-title {
    color: var(--header-fg, var(--color-primary));
  }

  .site-header--transparent .main-nav a {
    color: var(--header-fg, var(--color-text-muted));
  }

  .site-header--transparent.is-scrolled .site-title {
    color: var(--color-primary);
  }

  .site-header--transparent.is-scrolled .main-nav a {
    color: var(--color-text-muted);
  }

  .site-header--transparent.is-scrolled .main-nav a:hover,
  .site-header--transparent.is-scrolled .main-nav a.active {
    color: var(--color-secondary);
  }

  .nav-toggle {
    display: none;
    flex-direction: column;
    gap: 4px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .nav-toggle-bar {
    width: 24px;
    height: 2px;
    background: var(--color-primary);
    transition: transform 0.2s;
  }

  /* --breakpoint-md (768px) */
  @media (max-width: 768px) {
    .nav-toggle {
      display: flex;
    }

    .main-nav {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background: var(--color-surface);
      border-bottom: 1px solid var(--color-border);
      padding: 1rem 1.5rem;
    }

    .main-nav.open {
      display: block;
    }

    .main-nav ul {
      flex-direction: column;
      gap: 0.75rem;
    }
  }
</style>
