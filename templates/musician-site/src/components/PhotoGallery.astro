---
import { Image } from "astro:assets";
import Lightbox from "./Lightbox";
import type { ImageMetadata } from "astro";

interface Photo {
  src: ImageMetadata;
  alt: string;
  caption?: string;
}

interface Props {
  photos: Photo[];
}

const { photos } = Astro.props;

// Extract resolved string URLs for the React Lightbox (can't pass ImageMetadata to React)
const lightboxImages = photos.map((photo) => ({
  src: photo.src.src,
  alt: photo.alt,
  caption: photo.caption,
}));
---

<div class="photo-gallery-grid">
  {photos.map((photo, i) => (
    <button
      class="photo-gallery-item"
      data-photo-index={i}
      aria-label={`View ${photo.alt}`}
    >
      <div class="photo-thumb">
        <Image src={photo.src} alt={photo.alt} />
      </div>
      {photo.caption && <span class="photo-gallery-caption">{photo.caption}</span>}
    </button>
  ))}
</div>

<Lightbox client:only="react" images={lightboxImages} />

<script>
  document.querySelectorAll<HTMLButtonElement>("[data-photo-index]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const index = Number(btn.dataset.photoIndex);
      window.dispatchEvent(new CustomEvent("open-lightbox", { detail: { index } }));
    });
  });
</script>

<style>
  .photo-gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 280px), 1fr));
    gap: 1.5rem;
  }

  .photo-gallery-item {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    border-radius: var(--radius);
    overflow: hidden;
    text-align: left;
  }

  .photo-thumb {
    aspect-ratio: 4/3;
    overflow: hidden;
  }

  .photo-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .photo-gallery-caption {
    display: block;
    padding: 0.5rem 0;
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
  }
</style>
