---
import { getCollection } from "astro:content";

const quoteEntries = await getCollection("pressQuotes");
const quotes = quoteEntries.map((e) => e.data);
---

{quotes.length > 0 && (
  <div class="quote-list">
    {quotes.map((q) => (
      <blockquote class="quote-card">
        <p>"{q.quote}"</p>
        <footer>
          {q.url ? (
            <a href={q.url} target="_blank" rel="noopener noreferrer">{q.source}</a>
          ) : (
            <span>{q.source}</span>
          )}
        </footer>
      </blockquote>
    ))}
  </div>
)}

<style>
  .quote-list {
    display: grid;
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  .quote-card {
    background: var(--color-surface);
    border-left: 4px solid var(--color-secondary);
    padding: 1.5rem;
    border-radius: var(--radius);
  }

  .quote-card p {
    font-size: var(--font-size-lg);
    font-style: italic;
    line-height: 1.6;
  }

  .quote-card footer {
    margin-top: 0.75rem;
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
  }
</style>
