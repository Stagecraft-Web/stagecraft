---
/**
 * Astro wrapper around the shared React `Button` primitive in
 * `src/components/react/Button.tsx`. Astro server-renders the component to
 * plain HTML at build time (no React runtime ships to the client) so the
 * Markdoc-tag and `.astro`-template call sites stay HTML-native:
 *
 *   <Button href="/about" variant="outline">Learn more</Button>
 *
 * while the in-page React sidebar consumes the same primitive directly.
 * Single source of truth for the visual style across surfaces.
 */
import ButtonReact from "../../components/react/Button";
import type { ButtonVariant } from "../_shared/types";

interface Props {
  href?: string;
  variant?: ButtonVariant;
  ariaLabel?: string;
  type?: "button" | "submit" | "reset";
  class?: string;
  isExternal?: boolean;
  isDownload?: boolean;
  /** Used by Markdoc-tag callers (no slot content). */
  label?: string;
}

const { class: className, ...rest } = Astro.props;
---

<ButtonReact {...rest} className={className}>
  <slot />
</ButtonReact>
