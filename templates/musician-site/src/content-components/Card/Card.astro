---
// Card — the generic tile primitive.
//
// Used two ways:
//   1. Directly by authors via `{% card %}` in markdoc (string `media`/`file`).
//   2. Internally by specialised list components (ReleaseList, PostsList) that
//      hand in pre-resolved ImageMetadata and compose buttons/links in slots.
//
// Structure (all sections optional, all slots conditional):
//
//   <article|a>
//     └── media area (optional — 4:3 by default)
//         └── dispatched by mediaKind: <img>, <audio>, <video>, icon tile
//     └── content
//         ├── eyebrow (small uppercase label)
//         ├── title   (styled line, NOT a heading — by design, so cards in
//         │            a grid don't pollute the doc outline)
//         ├── meta    (small secondary line: date, type, …)
//         ├── body slot (main prose — markdoc content or slotted JSX)
//         └── footer (size label + download button + footer slot contents)
//
// Media kind is inferred from the file extension when `mediaKind` is unset
// or "auto" (see inferMediaKind.ts). Authors can override for edge cases.

import { Image as AstroImage } from "astro:assets";
import type { ImageMetadata } from "astro";
import Lightbox from "../../components/Lightbox";
import Button from "../Button/Button.astro";
import type {
  CardMediaAspect,
  CardMediaKind,
  CardOrientation,
  CardSize,
  CardVariant,
} from "../_shared/types";
import { defaultAspectForKind, inferMediaKind } from "./inferMediaKind";

interface Props {
  // --- Container ---
  variant?: CardVariant;
  orientation?: CardOrientation;
  size?: CardSize;
  /** Adds a lift-on-hover effect. Pairs naturally with `href`. */
  hover?: boolean;
  /** Extra class on the root — useful for internal callers (ReleaseList) that
   *  want to target specific cards without reaching into Card's internals. */
  class?: string;

  // --- Whole-card link ---
  href?: string;
  /** Opens `href` in a new tab. */
  isExternal?: boolean;

  // --- Media ---
  /** File path (resolved against src/assets/downloads/) or URL, OR a
   *  pre-resolved Astro ImageMetadata (from internal callers). */
  media?: string | ImageMetadata;
  mediaKind?: CardMediaKind;
  mediaAspect?: CardMediaAspect;
  /** Required alt text when `mediaKind` is "photo" (or inferred as such). */
  mediaAlt?: string;

  // --- Built-in metadata ---
  eyebrow?: string;
  title?: string;
  meta?: string;

  // --- Download affordance ---
  /** When set, renders a "Download" button in the footer. */
  file?: string;
  sizeLabel?: string;
}

const {
  variant = "filled",
  orientation = "vertical",
  size = "md",
  hover = false,
  class: className,
  href,
  isExternal = false,
  media,
  mediaKind: mediaKindProp,
  mediaAspect: mediaAspectProp,
  mediaAlt,
  eyebrow,
  title,
  meta,
  file,
  sizeLabel,
} = Astro.props;

// ---------------------------------------------------------------------------
// File resolution — same pattern as Download.astro / resolve-image.ts.
//
// `media` and `file` can each be:
//   - ImageMetadata (only `media`, from internal Astro callers — pass through)
//   - absolute URL ("http(s)://", "//", "/")   — use as-is
//   - bare filename / relative path            — look up in the downloads
//                                                asset glob
//
// When `media` is omitted but `file` is set, the file doubles as the preview
// source (classic download-card ergonomics).
// ---------------------------------------------------------------------------

const imageModules = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/downloads/**/*.{png,jpg,jpeg,svg,webp,avif,gif}",
  { eager: true },
);
const assetModules = import.meta.glob<{ default: string }>(
  "/src/assets/downloads/**/*",
  { eager: true, query: "?url", import: "default" },
);

function isAbsoluteUrl(path: string): boolean {
  return /^(?:https?:\/\/|\/\/|\/)/.test(path);
}

function lookupImage(path: string): ImageMetadata | undefined {
  const filename = path.split("/").pop();
  if (!filename) return undefined;
  const match = Object.entries(imageModules).find(([key]) =>
    key.endsWith(`/${filename}`),
  );
  return match?.[1]?.default;
}

function lookupAssetUrl(path: string): string | undefined {
  const filename = path.split("/").pop();
  if (!filename) return undefined;
  const match = Object.entries(assetModules).find(([key]) =>
    key.endsWith(`/${filename}`),
  );
  const resolved = match?.[1];
  return typeof resolved === "string" ? resolved : undefined;
}

// Strings we need for URLs (download button, plain <a href>, audio/video src)
// vs. ImageMetadata we need for AstroImage (optimisation).
//
// Only treat `media` as a path string when it's actually a string. Anything
// object-shaped is treated as ImageMetadata so we never pass non-strings
// into the path inference / glob lookup helpers.
const mediaIsString = typeof media === "string";
const mediaIsImageMetadata =
  !mediaIsString && typeof media === "object" && media !== null;
const mediaPathString: string | undefined = mediaIsString
  ? (media as string)
  : undefined;

// Effective "what does the preview look at" — media takes precedence; fall
// through to file if media isn't set (download card pattern).
const previewPath = mediaPathString ?? file;

// Kind is either explicit (author set it), auto-inferred, or derived from
// absence ("none" when no preview source at all).
const resolvedKind: CardMediaKind =
  !mediaKindProp || mediaKindProp === "auto"
    ? mediaIsImageMetadata
      ? "photo"
      : inferMediaKind(previewPath)
    : mediaKindProp;

const resolvedAspect: CardMediaAspect =
  mediaAspectProp ?? defaultAspectForKind(resolvedKind);

// Resolve image metadata for AstroImage (only photos; only when bundled).
const bundledImage: ImageMetadata | undefined = mediaIsImageMetadata
  ? (media as ImageMetadata)
  : resolvedKind === "photo" && previewPath && !isAbsoluteUrl(previewPath)
    ? lookupImage(previewPath)
    : undefined;

// Resolve plain URL string for any other media (audio/video src, fallback
// photo <img>, and the download button's href).
const bundledUrl: string | undefined =
  previewPath && !isAbsoluteUrl(previewPath)
    ? lookupAssetUrl(previewPath)
    : undefined;

const mediaUrl: string | undefined = mediaIsImageMetadata
  ? (media as ImageMetadata).src
  : previewPath && isAbsoluteUrl(previewPath)
    ? previewPath
    : bundledImage?.src ?? bundledUrl;

// The download button's href: if `file` is explicitly set, use it; otherwise
// reuse whatever the media resolves to (author didn't bother separating the
// two — same file serves both preview and download).
const downloadHref: string | undefined = file
  ? isAbsoluteUrl(file)
    ? file
    : (() => {
        const imageHit = lookupImage(file);
        return imageHit?.src ?? lookupAssetUrl(file);
      })()
  : undefined;

const downloadFilename = file?.split("/").pop() ?? file;

// Lightbox wiring — each photo card gets its own event namespace so multiple
// cards on the same page don't all open the same lightbox together.
const hasLightbox = resolvedKind === "photo" && !!bundledImage && !href;
const lightboxEventName = hasLightbox
  ? `card-lightbox-${(title ?? file ?? mediaUrl ?? "x")
      .toString()
      .replace(/\W+/g, "-")
      .toLowerCase()}`
  : null;

// Render the outer element as an anchor if `href` is set; the Card never
// nests a lightbox-button inside an anchor (interaction would conflict).
const Tag = href ? "a" : "article";
const tagAttrs = href
  ? {
      href,
      ...(isExternal ? { target: "_blank", rel: "noopener noreferrer" } : {}),
    }
  : {};

const rootClass = [
  "card",
  `card-${variant}`,
  `card-${orientation}`,
  `card-${size}`,
  hover ? "card-hover" : null,
  resolvedKind !== "none" ? "card-has-media" : "card-no-media",
  href ? "card-as-link" : null,
  className,
]
  .filter(Boolean)
  .join(" ");
---

<Tag class={rootClass} {...tagAttrs}>
  {resolvedKind !== "none" && mediaUrl && (
    <div
      class={`card-media card-media-${resolvedKind} card-media-aspect-${resolvedAspect.replace(":", "-")}`}
      data-kind={resolvedKind}
    >
      {resolvedKind === "photo" && bundledImage && hasLightbox && (
        <>
          <button
            type="button"
            class="card-photo-btn"
            data-lightbox-trigger={lightboxEventName}
            aria-label={`View ${title ?? mediaAlt ?? "image"}`}
          >
            <AstroImage
              src={bundledImage}
              alt={mediaAlt ?? title ?? ""}
              loading="lazy"
              class="card-photo-img"
            />
          </button>
          <Lightbox
            client:only="react"
            eventName={lightboxEventName ?? undefined}
            images={[{ src: bundledImage.src, alt: mediaAlt ?? title ?? "", caption: meta }]}
          />
        </>
      )}

      {resolvedKind === "photo" && bundledImage && !hasLightbox && (
        <AstroImage
          src={bundledImage}
          alt={mediaAlt ?? title ?? ""}
          loading="lazy"
          class="card-photo-img"
        />
      )}

      {resolvedKind === "photo" && !bundledImage && (
        <img
          src={mediaUrl}
          alt={mediaAlt ?? title ?? ""}
          loading="lazy"
          class="card-photo-img"
        />
      )}

      {resolvedKind === "audio" && (
        <audio controls preload="metadata" class="card-audio">
          <source src={mediaUrl} />
          Your browser doesn't support inline audio.
        </audio>
      )}

      {resolvedKind === "video" && (
        <video controls preload="metadata" class="card-video">
          <source src={mediaUrl} />
          Your browser doesn't support inline video.
        </video>
      )}

      {(resolvedKind === "pdf" || resolvedKind === "icon") && (
        <div class={`card-icon-tile card-icon-${resolvedKind}`}>
          <div class="card-icon-glyph" aria-hidden="true">
            {resolvedKind === "pdf" ? (
              <svg
                width="44"
                height="44"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.25"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                <polyline points="14 2 14 8 20 8" />
                <text x="12" y="17" text-anchor="middle" font-size="5.5" fill="currentColor" stroke="none" font-family="sans-serif" font-weight="700">PDF</text>
              </svg>
            ) : (
              <svg
                width="44"
                height="44"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.25"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                <polyline points="14 2 14 8 20 8" />
              </svg>
            )}
          </div>
          {downloadFilename && (
            <div class="card-icon-filename">{downloadFilename}</div>
          )}
        </div>
      )}
    </div>
  )}

  <div class="card-content">
    {(eyebrow || title || meta) && (
      <div class="card-heading">
        {eyebrow && <div class="card-eyebrow">{eyebrow}</div>}
        {title && <div class="card-title">{title}</div>}
        {meta && <div class="card-meta">{meta}</div>}
      </div>
    )}

    {Astro.slots.has("default") && (
      <div class="card-body">
        <slot />
      </div>
    )}

    {(sizeLabel || downloadHref || Astro.slots.has("footer")) && (
      <div class="card-footer">
        {sizeLabel && <span class="card-size">{sizeLabel}</span>}
        {downloadHref && (
          <Button
            href={downloadHref}
            variant="outline"
            isDownload
            label={`Download${(resolvedKind === "pdf" || resolvedKind === "icon") && downloadFilename ? ` ${downloadFilename}` : ""}`}
            class="card-download-btn"
          />
        )}
        <slot name="footer" />
      </div>
    )}
  </div>
</Tag>

{hasLightbox && lightboxEventName && (
  <script is:inline define:vars={{ lightboxEventName }}>
    document
      .querySelectorAll(`[data-lightbox-trigger="${lightboxEventName}"]`)
      .forEach((btn) => {
        btn.addEventListener("click", () => {
          window.dispatchEvent(
            new CustomEvent(lightboxEventName, { detail: { index: 0 } }),
          );
        });
      });
  </script>
)}

<style>
  /* =========================================================================
     Container
     ========================================================================= */

  .card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    color: inherit;
    text-decoration: none;
    min-width: 0;           /* allow shrinking inside grids */
  }

  .card-horizontal {
    flex-direction: row;
    align-items: stretch;
  }

  /* --- sizes ------------------------------------------------------------- */

  .card-sm {
    gap: 0.5rem;
  }

  .card-md {
    gap: 0.75rem;
  }

  .card-lg {
    gap: 1rem;
  }

  /* --- variants ---------------------------------------------------------- */

  .card-filled {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .card-outlined {
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .card-bare {
    /* No chrome — the caller is responsible for any surrounding container. */
  }

  /* Filled / outlined variants pad their content; bare does not, so adjacent
     prose can sit flush against the media. */
  .card-filled .card-content,
  .card-outlined .card-content {
    padding: 1rem 1.25rem 1.25rem;
  }

  .card-filled.card-sm .card-content,
  .card-outlined.card-sm .card-content {
    padding: 0.75rem 0.875rem 1rem;
  }

  .card-filled.card-lg .card-content,
  .card-outlined.card-lg .card-content {
    padding: 1.25rem 1.5rem 1.5rem;
  }

  /* In horizontal filled/outlined, the media area sits flush-left; padding
     goes on content only (mirroring PostsList's pre-refactor behaviour). */
  .card-filled.card-horizontal .card-media,
  .card-outlined.card-horizontal .card-media {
    border-radius: 0;
  }

  /* Hover affordance — opt-in via `hover` prop. */
  .card-hover {
    transition: transform 150ms ease, box-shadow 150ms ease;
  }

  .card-hover:hover,
  .card-hover:focus-visible {
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(0, 0, 0, 0.08);
  }

  /* =========================================================================
     Media area
     ========================================================================= */

  .card-media {
    position: relative;
    width: 100%;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-background);
  }

  /* Media sits flush against card edges for filled/outlined variants. Bare
     variant inherits the container radius. */
  .card-bare .card-media {
    border-radius: var(--radius);
  }

  /* --- horizontal orientation sizes the media column ---- */

  .card-horizontal .card-media {
    width: auto;
    flex-shrink: 0;
    align-self: stretch;
    /* A sensible default width at md; sm / lg nudge it. Large enough to
       read content, small enough not to dominate on narrow screens. */
    width: 12rem;
  }

  .card-horizontal.card-sm .card-media {
    width: 9rem;
  }

  .card-horizontal.card-lg .card-media {
    width: 14rem;
  }

  /* --- aspect ratios ----------------------------------------------------- */

  .card-media-aspect-4-3 {
    aspect-ratio: 4 / 3;
  }
  .card-media-aspect-1-1 {
    aspect-ratio: 1 / 1;
  }
  .card-media-aspect-16-9 {
    aspect-ratio: 16 / 9;
  }
  .card-media-aspect-auto {
    aspect-ratio: auto;
  }

  /* Horizontal cards let the media area take the card's full height rather
     than using a fixed aspect-ratio — matches PostsList list-mode sizing. */
  .card-horizontal .card-media {
    aspect-ratio: auto;
    height: auto;
  }

  /* --- photo kind -------------------------------------------------------- */

  .card-photo-btn {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    display: block;
    width: 100%;
    height: 100%;
    line-height: 0;
  }

  .card-photo-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* --- audio kind -------------------------------------------------------- */

  .card-audio {
    width: calc(100% - 1.5rem);
    max-width: 24rem;
  }

  /* --- video kind -------------------------------------------------------- */

  .card-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    background: var(--color-background);
  }

  /* --- pdf / icon kinds -------------------------------------------------- */

  .card-icon-tile {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 1rem;
    color: var(--color-text-muted);
  }

  .card-icon-glyph {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .card-icon-filename {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    text-align: center;
    word-break: break-all;
    max-width: 100%;
  }

  /* =========================================================================
     Content (heading + body + footer)
     ========================================================================= */

  .card-content {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  .card-heading {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .card-eyebrow {
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-secondary);
    font-weight: var(--font-weight-semibold);
  }

  /* `card-title` is a styled DIV, not a heading element, by explicit design.
     Cards can appear in lists/grids inside sections that already own the
     heading hierarchy; using h3/h4 here would pollute the accessibility
     outline without clear authorial intent. */
  .card-title {
    font-weight: var(--font-weight-semibold);
    font-size: var(--font-size-lg);
    line-height: 1.3;
    color: var(--color-text);
  }

  .card-sm .card-title {
    font-size: var(--font-size-base);
  }

  .card-lg .card-title {
    font-size: var(--font-size-xl);
  }

  .card-meta {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
  }

  .card-body {
    color: var(--color-text);
  }

  /* Body prose paragraphs — lean on global.css p styles but trim their
     bottom margin inside a card (the card's flex gap handles spacing). */
  .card-body :global(p) {
    margin: 0 0 0.5rem;
  }

  .card-body :global(p:last-child) {
    margin-bottom: 0;
  }

  .card-footer {
    margin-top: auto;   /* sticks to bottom in horizontal/grid cards */
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .card-size {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
  }

  /* =========================================================================
     Link affordance
     ========================================================================= */

  /* Whole-card anchors shouldn't look like underlined links. */
  .card-as-link {
    color: inherit;
  }

  .card-as-link:hover {
    text-decoration: none;
  }

  /* =========================================================================
     Responsive
     ========================================================================= */

  /* Horizontal cards stack on narrow screens — a 12rem media column is too
     much on phones. This is the same breakpoint PostsList used. */
  @media (max-width: 640px) {
    .card-horizontal {
      flex-direction: column;
    }

    .card-horizontal .card-media {
      width: 100%;
      aspect-ratio: 4 / 3;
    }
  }
</style>
