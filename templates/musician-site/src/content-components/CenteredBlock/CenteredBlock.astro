---
import type { CenteredBlockMaxWidth } from "../_shared/types";

interface Props {
  /** Preset for the inner column's max-width. */
  maxWidth?: CenteredBlockMaxWidth;
}

const { maxWidth = "narrow" } = Astro.props;
---

<div class:list={["centered-block", `centered-block--${maxWidth}`]}>
  <slot />
</div>

<style>
  .centered-block {
    margin-inline: auto;
    text-align: center;
  }

  .centered-block--narrow {
    max-width: 60ch;
  }

  .centered-block--regular {
    max-width: var(--max-text);
  }

  /* Pull-through: centered buttons should still sit horizontally centered in
     their own line, not stretch to the column width. Scoped to the wrapper so
     unrelated buttons elsewhere on the page are untouched. */
  .centered-block :global(.btn) {
    margin-inline: auto;
  }
</style>
