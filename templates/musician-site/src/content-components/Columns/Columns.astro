---
import type { ColumnsLayout } from "../_shared/types";
import { parseColumnsLayout } from "../_shared/parseColumnsLayout";

interface Props {
  /** Column proportions separated by dashes, e.g. "1-1", "1-2", "2-1", "1-1-1" */
  layout?: ColumnsLayout;
}

const { layout = "1-1" } = Astro.props;
// `parseColumnsLayout` accepts arbitrary strings as a defensive fallback; the
// prop type narrows what authors can pass via Markdoc, but we still funnel
// through the same parser the preview uses for consistency.
const gridColumns = parseColumnsLayout(layout);
---

<div class="columns" style={`--columns: ${gridColumns}`}>
  <slot />
</div>

<style>
  .columns {
    display: grid;
    grid-template-columns: var(--columns);
    gap: 2rem;
    align-items: start;
  }

  /* --breakpoint-md (768px) */
  @media (max-width: 768px) {
    .columns {
      grid-template-columns: 1fr;
    }
  }
</style>
