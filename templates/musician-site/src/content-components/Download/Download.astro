---
// Download — a single downloadable file rendered with a kind-specific preview.
//
// Kind     Preview                                      Behaviour
// ──────── ──────────────────────────────────────────── ──────────────────────
// photo    Thumbnail <img>, clickable                   Click opens Lightbox
// audio    <audio controls preload="metadata">          Plays inline
// video    <video controls>                             Plays inline  *1
// pdf      Large PDF icon + filename                    Download-only
// other    Generic file icon + filename                 Download-only
//
// Every kind also renders a dedicated "Download" button that triggers a direct
// save via `<a download>` — the preview and the download are distinct
// affordances so users can sample first, then save.
//
// *1 — We use native <video controls> rather than VideoLightbox because
//    VideoLightbox is iframe-only (YouTube / Vimeo embeds). For downloadable
//    video *files* (.mp4, .webm, .mov), native <video> is simpler and more
//    reliable: no JS payload, works offline, and the same file serves both
//    preview and download. This choice is documented in the PR body.
//
// File resolution:
//   - `http://`, `https://`, `//`, `/` prefixes → treated as external/absolute
//     URLs and used as-is.
//   - Anything else                             → resolved against
//     `src/assets/downloads/` via `import.meta.glob`. Bundled through Vite so
//     the final URL is content-hashed and cache-stable. We pull the filename
//     off the path rather than matching the full path, mirroring
//     `resolve-image.ts` — this means filenames must be unique across
//     subdirectories of src/assets/downloads/.

import { Image as AstroImage } from "astro:assets";
import type { ImageMetadata } from "astro";
import Lightbox from "../../components/Lightbox";
import Button from "../Button/Button.astro";
import type { DownloadKind } from "../_shared/types";

interface Props {
  label: string;
  file: string;
  kind?: DownloadKind;
  description?: string;
  credit?: string;
  sizeLabel?: string;
}

const {
  label,
  file,
  kind = "other",
  description,
  credit,
  sizeLabel,
} = Astro.props;

// ---------------------------------------------------------------------------
// File resolution
// ---------------------------------------------------------------------------

// For the <Image> component we need ImageMetadata (optimised, hashed at build
// time). For everything else a plain URL string suffices. We eagerly index
// both pools so Vite can tree-shake the unused branch per build.
const imageModules = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/downloads/**/*.{png,jpg,jpeg,svg,webp,avif,gif}",
  { eager: true },
);
const assetModules = import.meta.glob<{ default: string }>(
  "/src/assets/downloads/**/*",
  { eager: true, query: "?url", import: "default" },
);

function isExternal(path: string): boolean {
  return /^(?:https?:\/\/|\/\/|\/)/.test(path);
}

function resolveImage(path: string): ImageMetadata | undefined {
  const filename = path.split("/").pop();
  if (!filename) return undefined;
  const match = Object.entries(imageModules).find(([key]) =>
    key.endsWith(`/${filename}`),
  );
  return match?.[1]?.default;
}

function resolveAssetUrl(path: string): string | undefined {
  const filename = path.split("/").pop();
  if (!filename) return undefined;
  const match = Object.entries(assetModules).find(([key]) =>
    key.endsWith(`/${filename}`),
  );
  const resolved = match?.[1];
  return typeof resolved === "string" ? resolved : undefined;
}

const filename = file.split("/").pop() ?? file;
const hasExternalUrl = isExternal(file);

// Resolve photo kind through AstroImage when bundled for optimisation;
// otherwise use the raw URL.
const bundledImage = !hasExternalUrl && kind === "photo" ? resolveImage(file) : undefined;
const bundledUrl = !hasExternalUrl ? resolveAssetUrl(file) : undefined;
const downloadUrl: string | undefined = hasExternalUrl
  ? file
  : bundledImage?.src ?? bundledUrl;

// A stable per-instance id so multiple Download photos on the same page each
// get their own Lightbox event namespace. `Astro.self` isn't unique across
// SSR of the same component; we derive a token from label + file, which is
// unique in practice (and stable across renders, unlike random).
const instanceId = `dl-${label.replace(/\W+/g, "-").toLowerCase()}-${file
  .split("/")
  .pop()
  ?.replace(/\W+/g, "-")
  .toLowerCase()}`;
const lightboxEventName = `open-lightbox-${instanceId}`;
---

{downloadUrl && (
  <article class={`download download-${kind}`} data-kind={kind}>
    <div class="download-preview">
      {kind === "photo" && bundledImage && (
        <>
          <button
            type="button"
            class="download-photo-btn"
            data-lightbox-trigger={lightboxEventName}
            aria-label={`View ${label}`}
          >
            <AstroImage
              src={bundledImage}
              alt={label}
              loading="lazy"
              class="download-photo-thumb"
            />
          </button>
          <Lightbox
            client:only="react"
            eventName={lightboxEventName}
            images={[{ src: bundledImage.src, alt: label, caption: credit }]}
          />
        </>
      )}

      {kind === "photo" && !bundledImage && (
        <a
          href={downloadUrl}
          class="download-photo-btn"
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`View ${label}`}
        >
          <img
            src={downloadUrl}
            alt={label}
            loading="lazy"
            class="download-photo-thumb"
          />
        </a>
      )}

      {kind === "audio" && (
        <audio controls preload="metadata" class="download-audio">
          <source src={downloadUrl} />
          Your browser doesn't support inline audio.
        </audio>
      )}

      {kind === "video" && (
        <video controls preload="metadata" class="download-video">
          <source src={downloadUrl} />
          Your browser doesn't support inline video.
        </video>
      )}

      {(kind === "pdf" || kind === "other") && (
        <div class={`download-icon-tile download-icon-${kind}`} aria-hidden="true">
          {kind === "pdf" ? (
            <svg
              width="44"
              height="44"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.25"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
              <polyline points="14 2 14 8 20 8" />
              <text x="12" y="17" text-anchor="middle" font-size="5.5" fill="currentColor" stroke="none" font-family="sans-serif" font-weight="700">PDF</text>
            </svg>
          ) : (
            <svg
              width="44"
              height="44"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.25"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
              <polyline points="14 2 14 8 20 8" />
            </svg>
          )}
        </div>
      )}
    </div>

    <div class="download-meta">
      <div class="download-label">{label}</div>
      {description && <div class="download-description">{description}</div>}
      {credit && <div class="download-credit">{credit}</div>}
      <div class="download-footer">
        {sizeLabel && <span class="download-size">{sizeLabel}</span>}
        <Button
          href={downloadUrl}
          variant="outline"
          isDownload
          label={`Download${(kind === "pdf" || kind === "other") ? ` ${filename}` : ""}`}
          class="download-btn"
        />
      </div>
    </div>
  </article>
)}

{downloadUrl && kind === "photo" && bundledImage && (
  <script is:inline define:vars={{ lightboxEventName }}>
    document
      .querySelectorAll(`[data-lightbox-trigger="${lightboxEventName}"]`)
      .forEach((btn) => {
        btn.addEventListener("click", () => {
          window.dispatchEvent(
            new CustomEvent(lightboxEventName, { detail: { index: 0 } }),
          );
        });
      });
  </script>
)}

<style>
  .download {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1rem;
    padding: 0.875rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    background: var(--color-surface);
    align-items: start;
  }

  /* Grid layout — stack preview above meta for card-like items. */
  :global(.downloads-grid) .download {
    grid-template-columns: 1fr;
  }

  .download-preview {
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 8rem;
  }

  :global(.downloads-grid) .download-preview {
    min-width: 0;
  }

  .download-photo-btn {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    display: block;
    border-radius: var(--radius);
    overflow: hidden;
    line-height: 0;
  }

  .download-photo-thumb {
    display: block;
    width: auto;
    max-width: 100%;
    max-height: 240px;
    object-fit: cover;
    border-radius: var(--radius);
  }

  .download-audio,
  .download-video {
    width: 100%;
    max-width: 320px;
    border-radius: var(--radius);
  }

  :global(.downloads-grid) .download-audio,
  :global(.downloads-grid) .download-video {
    max-width: 100%;
  }

  .download-icon-tile {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 5.5rem;
    height: 5.5rem;
    color: var(--color-text-muted);
    background: var(--color-background);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
  }

  .download-meta {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .download-label {
    font-weight: var(--font-weight-semibold);
    font-size: var(--font-size-base);
    color: var(--color-text);
  }

  .download-description {
    font-size: var(--font-size-sm);
    color: var(--color-text);
  }

  .download-credit {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    font-style: italic;
  }

  .download-footer {
    margin-top: 0.5rem;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .download-size {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
  }

  /* Small-screen: always stack preview above meta regardless of layout. */
  @media (max-width: 540px) {
    .download {
      grid-template-columns: 1fr;
    }
  }
</style>
