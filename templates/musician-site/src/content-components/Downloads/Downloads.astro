---
// Downloads — wrapper around a list of `{% download %}` blocks.
//
// Renders a labelled, iconified list of downloadable assets (press photos,
// PDFs, audio stems, video clips, stage plots). The actual per-item rendering
// is handled by each child `{% download %}` tag (see Download/Download.astro);
// this wrapper owns the optional section heading and the layout variant
// (list vs. grid) via a CSS variable that the child items consume.
//
// Example:
//   {% downloads title="Press kit" layout="list" %}
//     {% download label="Press photo (web)" file="./press-web.jpg" kind="photo" /%}
//     {% download label="One-sheet" file="./one-sheet.pdf" kind="pdf" /%}
//   {% /downloads %}
import type { DownloadsLayout } from "../_shared/types";

interface Props {
  /** Optional section heading rendered above the list. */
  title?: string;
  /** Layout variant for child items. Defaults to `list`. */
  layout?: DownloadsLayout;
}

const { title, layout = "list" } = Astro.props;
---

<section class={`downloads downloads-${layout}`} data-layout={layout}>
  {title && <h3 class="downloads-title">{title}</h3>}
  <div class="downloads-items">
    <slot />
  </div>
</section>

<style>
  .downloads {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .downloads-title {
    margin: 0;
    font-size: var(--font-size-xl);
  }

  .downloads-items {
    display: grid;
    gap: 1rem;
  }

  .downloads-list .downloads-items {
    grid-template-columns: 1fr;
  }

  .downloads-grid .downloads-items {
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 280px), 1fr));
  }
</style>
