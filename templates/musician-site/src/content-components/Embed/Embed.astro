---
/**
 * `embed` — render a sanitized iframe from a raw author-provided embed snippet.
 *
 * The renderer does NOT pass the author's HTML through verbatim. We extract
 * the iframe element via ./extractIframe.ts (which allowlists attributes,
 * see that file for the rationale), then rebuild the element here using
 * Astro's expression interpolation so every attribute value is properly
 * escaped. This keeps the trust boundary inside the parser — anything
 * surprising in the snippet is dropped before it reaches the page.
 *
 * Sizing
 * ------
 * No magic. The iframe renders at whatever width/height its source attributes
 * specify (Bandcamp's 350×470 player stays 350×470). The only default is
 * `max-width: 100%` so a hardcoded-pixel embed can't horizontally overflow
 * its column on a narrow viewport.
 *
 * Want responsive scaling (fill the column, maintain aspect ratio)? Use
 * `{% responsive-embed %}` instead.
 *
 * Title fallback chain
 * --------------------
 * Author-provided `title` field → original iframe title attribute → a
 * generic "Embedded content from <host>" string. Always set so the iframe
 * has an a11y label.
 */
import { extractIframe, buildIframeAttrs, type IframeAttrs } from "./extractIframe";

interface Props {
  code: string;
  title?: string;
}

const { code, title } = Astro.props;

const parsed = extractIframe(code);
const attrs: IframeAttrs | null = parsed ? buildIframeAttrs(parsed, { title }) : null;
---

{attrs === null ? (
  <div class="embed-error" role="alert">
    <strong>Embed code couldn't be parsed.</strong>
    <span>Paste the full <code>&lt;iframe&gt;</code> snippet from the service's "Share / Embed" UI.</span>
  </div>
) : (
  <iframe class="embed" {...attrs} />
)}

<style>
  .embed {
    display: block;
    max-width: 100%;
    border: 0;
    margin: var(--space-md, 1rem) 0;
  }

  .embed-error {
    margin: var(--space-md, 1rem) 0;
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border, currentColor);
    border-left-width: 4px;
    border-left-color: var(--color-secondary, currentColor);
    border-radius: var(--radius, 4px);
    background: var(--color-surface, transparent);
    color: var(--color-text, inherit);
    font-size: var(--font-size-sm, 0.875rem);
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .embed-error code {
    font-family: var(--font-mono, ui-monospace, monospace);
  }
</style>
