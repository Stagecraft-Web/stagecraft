---
/**
 * `embed-responsive` — sanitized iframe wrapped in an aspect-ratio container
 * that scales to fill its parent column.
 *
 * Sizing
 * ------
 * The wrapper is `width: 100%; aspect-ratio: <ratio>`; the iframe is absolutely
 * positioned to fill it. Result: the embed grows to fill its column on wide
 * viewports and shrinks on narrow ones, always preserving the chosen ratio.
 *
 * `aspectRatio="auto"` (default) derives the ratio from the iframe's intrinsic
 * pixel dimensions (Bandcamp's `style="width: 350px; height: 470px"` becomes
 * `aspect-ratio: 350/470`). When intrinsic dimensions can't be derived (e.g.
 * Spotify's `width="100%"` snippet), we degrade to a plain Embed render — no
 * wrapper, no ratio.
 *
 * `maxWidth` is opt-in. By default the embed scales freely; a cap is useful
 * when the source player looks awkward stretched (e.g. a 350-wide Bandcamp
 * card on a 1200px column).
 *
 * Why a separate component instead of an `aspectRatio` attr on Embed
 * ------------------------------------------------------------------
 * Per PR review (and confirmed empirically — see Embed/schema.ts): keep
 * `Embed` straightforward (no magic) and put the aspect-ratio logic in this
 * sibling component. Keystatic's `block()` content-component API has no
 * parse/serialize hook to bridge a `fields.conditional` to flat Markdoc
 * tag attributes, so a single block with a "responsive" toggle that hides
 * dependent fields when off would silently drop existing tags. Two blocks
 * with one knob each sidesteps that limitation cleanly.
 *
 * Both components share `extractIframe` + `buildIframeAttrs` (in `../Embed/`)
 * so the parsing, sanitization, and attribute narrowing live in one place.
 */
import { extractIframe, buildIframeAttrs, type IframeAttrs } from "../Embed/extractIframe";
import type { EmbedAspectRatio } from "../_shared/types";

interface Props {
  code: string;
  aspectRatio?: EmbedAspectRatio;
  title?: string;
  maxWidth?: number;
  minHeight?: number;
}

const { code, aspectRatio = "auto", title, maxWidth, minHeight } = Astro.props;

const parsed = extractIframe(code);
const hasParseError = parsed === null;

// Resolve the effective ratio. Explicit ratio wins; "auto" looks at intrinsic
// dimensions; if neither is available we fall back to plain rendering (no
// wrapper) so a Spotify embed (width="100%") still shows up sensibly instead
// of collapsing to zero height.
const resolvedRatio: string | null = (() => {
  if (hasParseError) return null;
  if (aspectRatio !== "auto") return aspectRatio;
  if (parsed.intrinsicWidth !== null && parsed.intrinsicHeight !== null) {
    return `${parsed.intrinsicWidth} / ${parsed.intrinsicHeight}`;
  }
  return null;
})();

const isWrapped = resolvedRatio !== null;

// Strip width/height (attribute + inline style) only when a wrapper takes
// over sizing — otherwise the iframe's own dimensions still apply.
const attrs: IframeAttrs | null = parsed
  ? buildIframeAttrs(parsed, { title, stripDimensions: isWrapped })
  : null;

const wrapperDecls: string[] = [];
if (resolvedRatio) {
  wrapperDecls.push(`--embed-aspect-ratio: ${resolvedRatio}`);
}
if (typeof maxWidth === "number") {
  wrapperDecls.push(`max-width: ${maxWidth}px`);
}
if (typeof minHeight === "number") {
  wrapperDecls.push(`min-height: ${minHeight}px`);
}
const wrapperStyle = wrapperDecls.length > 0 ? wrapperDecls.join("; ") : undefined;
---

{hasParseError ? (
  <div class="embed-error" role="alert">
    <strong>Embed code couldn't be parsed.</strong>
    <span>Paste the full <code>&lt;iframe&gt;</code> snippet from the service's "Share / Embed" UI.</span>
  </div>
) : isWrapped ? (
  <div class="embed-responsive" style={wrapperStyle}>
    <iframe {...attrs} />
  </div>
) : (
  <iframe class="embed-responsive-passthrough" {...attrs} style={wrapperStyle} />
)}

<style>
  .embed-responsive {
    position: relative;
    width: 100%;
    aspect-ratio: var(--embed-aspect-ratio);
    margin: var(--space-md, 1rem) 0;
  }

  .embed-responsive iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  /*
   * Fallback when no ratio could be derived (e.g. Spotify's width="100%"
   * snippet in "auto" mode). The iframe carries its own width/height; we
   * just enforce max-width:100% and let the author's optional maxWidth /
   * minHeight apply via the inline style.
   */
  .embed-responsive-passthrough {
    display: block;
    max-width: 100%;
    border: 0;
    margin: var(--space-md, 1rem) 0;
  }

  .embed-error {
    margin: var(--space-md, 1rem) 0;
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border, currentColor);
    border-left-width: 4px;
    border-left-color: var(--color-secondary, currentColor);
    border-radius: var(--radius, 4px);
    background: var(--color-surface, transparent);
    color: var(--color-text, inherit);
    font-size: var(--font-size-sm, 0.875rem);
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .embed-error code {
    font-family: var(--font-mono, ui-monospace, monospace);
  }
</style>
