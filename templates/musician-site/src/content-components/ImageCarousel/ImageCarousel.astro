---
/**
 * `image-carousel` — thin Astro wrapper around the React island.
 *
 * Data source
 * -----------
 * Queries the `photos` collection. When `photosCollection` is set we filter
 * to entries whose `usageSlot` matches; `"all"` includes every photo.
 * (Inline-photos mode is not yet supported — see schema.ts TODO.)
 *
 * No-JS / pre-hydration behavior
 * ------------------------------
 * The React island is SSR'd (`client:visible`), so the rendered HTML is
 * already a functional scroll-snap track — visitors can swipe / wheel /
 * keyboard-scroll through every slide before JS arrives. Hydration only
 * adds the arrow + dot interactivity and the IntersectionObserver that
 * keeps active state in sync.
 *
 * Validation
 * ----------
 * Authors must leave at least one of (arrows, dots) visible. We render
 * an inline warning when both are hidden so editors catch the issue in
 * preview rather than at runtime.
 */
import { getCollection } from "astro:content";
// Import alias — the Astro file shares the `ImageCarousel` name with the
// component folder; the alias avoids colliding with the implicit Astro
// component declaration of the same name.
import ImageCarouselIsland from "./ImageCarousel";
import type { CarouselAspectRatio, PhotosFilter } from "./schema";

interface Props {
  /**
   * Photos-collection `usageSlot` filter. `"all"` (the default) shows
   * every photo; any IMAGE_USAGE_SLOTS member filters to photos whose
   * `usageSlot` matches.
   */
  photosCollection?: PhotosFilter;
  aspectRatio?: CarouselAspectRatio;
  areArrowsHidden?: boolean;
  areDotsHidden?: boolean;
}

const {
  photosCollection = "all",
  aspectRatio = "16/9",
  areArrowsHidden = false,
  areDotsHidden = false,
} = Astro.props;

const allPhotoEntries = await getCollection("photos");
const photoEntries =
  photosCollection === "all"
    ? allPhotoEntries
    : allPhotoEntries.filter((e) => e.data.usageSlot === photosCollection);

const photos = photoEntries.map((e) => e.data);

// The React island can't consume `ImageMetadata` objects directly — pass
// resolved string URLs (the `.src` attribute on the processed asset).
const islandSlides = photos.map((photo) => ({
  src: photo.src.src,
  alt: photo.alt,
  caption: photo.caption,
}));

const hasNavError = areArrowsHidden && areDotsHidden;
---

{hasNavError ? (
  <div class="image-carousel-error" role="alert">
    <strong>Image carousel is missing navigation controls.</strong>
    <span>
      Leave at least one of <em>arrows</em> or <em>dots</em> visible so
      visitors on touch and screen-reader devices can change slides.
    </span>
  </div>
) : photos.length > 0 ? (
  <ImageCarouselIsland
    client:visible
    slides={islandSlides}
    aspectRatio={aspectRatio}
    areArrowsHidden={areArrowsHidden}
    areDotsHidden={areDotsHidden}
  />
) : null}

<style>
  /*
   * Inline admin-preview error — mirrors the `embed-error` pattern in
   * Embed.astro so editors get consistent feedback across components.
   */
  .image-carousel-error {
    margin: var(--space-md, 1rem) 0;
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border, currentColor);
    border-left-width: 4px;
    border-left-color: var(--color-secondary, currentColor);
    border-radius: var(--radius, 4px);
    background: var(--color-surface, transparent);
    color: var(--color-text, inherit);
    font-size: var(--font-size-sm, 0.875rem);
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
</style>
