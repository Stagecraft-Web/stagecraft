---
/**
 * Newsletter email field — child tag of `{% newsletter-signup %}`.
 *
 * The email-specific block. Defaults `name="email"`, `label="Email"`,
 * `autocomplete="email"`, and `type="email"` on the input — Mailchimp users
 * who need uppercase `EMAIL` override `name`. Required by default since
 * every newsletter provider needs the subscriber's email address.
 */
import FormGroup from "../../components/FormGroup.astro";
import type { AutocompleteToken } from "../_shared/types";

interface Props {
  name?: string;
  label?: string;
  autocomplete?: AutocompleteToken;
  isRequired?: boolean;
  placeholder?: string;
}

const {
  name = "email",
  label = "Email",
  autocomplete = "email",
  isRequired = true,
  placeholder,
} = Astro.props;
---

<FormGroup
  type="email"
  name={name}
  label={label}
  autocomplete={autocomplete}
  isRequired={isRequired}
  placeholder={placeholder}
/>
