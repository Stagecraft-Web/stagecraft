---
/**
 * Newsletter field — a child tag of `{% newsletter-signup %}`. Each instance
 * renders one extra input (beyond the always-present email field) via the
 * shared `<FormGroup>` component.
 *
 * The `name` attribute is the raw form-field name passed to the newsletter
 * provider (e.g. `FNAME` for Mailchimp, `first_name` for ConvertKit). We
 * don't remap per service — providers consume the `name` verbatim, so authors
 * paste whatever their provider's embed code uses.
 *
 * `type="select"` uses a pipe-separated `options` string ("A|B|C") so markdoc
 * attribute values stay flat (no array-of-object parsing). Everything else
 * degrades to a native `<input>` of the matching type via FormGroup.
 */
import FormGroup from "../../components/FormGroup.astro";
import type { FieldType } from "../_shared/types";
import { parseFieldOptions } from "./parseFieldOptions";

interface Props {
  name: string;
  label: string;
  type?: FieldType;
  isRequired?: boolean;
  /** Pipe-separated choices for `type="select"`, e.g. `"Friend|Social|Other"`. */
  options?: string;
  placeholder?: string;
  autocomplete?: string;
}

const {
  name,
  label,
  type = "text",
  isRequired = false,
  options,
  placeholder,
  autocomplete,
} = Astro.props;

// Only consumed when `type === "select"`; other types ignore the value.
const selectOptions = type === "select" ? parseFieldOptions(options) : [];
---

{
  type === "select" ? (
    <div class="form-group">
      <label for={name}>
        {label}
        {isRequired && <span class="form-group-required">*</span>}
      </label>
      <select id={name} name={name} required={isRequired} autocomplete={autocomplete}>
        {!isRequired && <option value="">{placeholder ?? "Select an option"}</option>}
        {selectOptions.map((opt) => (
          <option value={opt}>{opt}</option>
        ))}
      </select>
    </div>
  ) : (
    <FormGroup
      label={label}
      name={name}
      type={type}
      isRequired={isRequired}
      autocomplete={autocomplete}
      placeholder={placeholder}
    />
  )
}

<style>
  /*
   * Select rendered inline here (rather than via FormGroup) because FormGroup
   * only knows about <input>/<textarea>. Styling mirrors FormGroup's input so
   * the controls look identical inside the newsletter form.
   */
  .form-group {
    margin-bottom: 1.25rem;
  }

  .form-group label {
    display: block;
    margin-bottom: 0.375rem;
    font-weight: var(--font-weight-medium);
    font-size: var(--font-size-sm);
  }

  .form-group-required {
    color: var(--color-secondary);
  }

  .form-group select {
    width: 100%;
    padding: 0.625rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    font-family: var(--font-body);
    font-size: var(--font-size-base);
    background: var(--color-surface);
    color: var(--color-text);
  }

  .form-group select:focus {
    outline: 2px solid var(--color-secondary);
    outline-offset: 1px;
    border-color: transparent;
  }
</style>
