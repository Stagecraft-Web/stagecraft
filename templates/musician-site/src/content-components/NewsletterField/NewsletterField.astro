---
/**
 * Newsletter field — a child tag of `{% newsletter-signup %}`. Each instance
 * renders one input via the shared `<FormGroup>` component (including the
 * mandatory email field, which authors must include explicitly with
 * `type="email"` — see NewsletterSignup/schema.ts validate).
 *
 * Smart defaults: when `type="email"` or `type="tel"` and the author hasn't
 * set `name` / `label` / `autocomplete`, fall back to common values from
 * `typeDefaults.ts`. So a minimal `{% newsletter-field type="email" /%}`
 * renders as a working "Email" input named `email` with `autocomplete="email"`.
 * The author can override any of those by setting the attribute explicitly.
 *
 * The `name` attribute (when set) is the raw form-field name passed to the
 * newsletter provider (e.g. `EMAIL` for Mailchimp, `email_address` for
 * ConvertKit). We don't remap per service — providers consume the `name`
 * verbatim, so authors paste whatever their provider's embed code uses.
 *
 * `type="select"` uses a pipe-separated `options` string ("A|B|C") so markdoc
 * attribute values stay flat (no array-of-object parsing). Everything else
 * degrades to a native `<input>` of the matching type via FormGroup.
 */
import FormGroup from "../../components/FormGroup.astro";
import type { AutocompleteToken, FieldType } from "../_shared/types";
import { parseFieldOptions } from "./parseFieldOptions";
import {
  DEFAULT_AUTOCOMPLETE_FOR_TYPE,
  DEFAULT_LABEL_FOR_TYPE,
  DEFAULT_NAME_FOR_TYPE,
} from "./typeDefaults";

interface Props {
  type?: FieldType;
  name?: string;
  label?: string;
  isRequired?: boolean;
  /** Pipe-separated choices for `type="select"`, e.g. `"Friend|Social|Other"`. */
  options?: string;
  placeholder?: string;
  autocomplete?: AutocompleteToken;
}

const {
  type = "text",
  name,
  label,
  isRequired = false,
  options,
  placeholder,
  autocomplete,
} = Astro.props;

// Apply type-based fallbacks for the common attributes. The schema's markdoc
// validate() guarantees that `name` and `label` are either set or have a
// type-default (email/tel only), so these `??` chains never end up undefined
// in practice — but TS doesn't know that, so the renderer tolerates a
// missing fallback by passing an empty string through.
const effectiveName = name ?? DEFAULT_NAME_FOR_TYPE[type] ?? "";
const effectiveLabel = label ?? DEFAULT_LABEL_FOR_TYPE[type] ?? "";
const effectiveAutocomplete = autocomplete ?? DEFAULT_AUTOCOMPLETE_FOR_TYPE[type];

// Only consumed when `type === "select"`; other types ignore the value.
const selectOptions = type === "select" ? parseFieldOptions(options) : [];
// FormGroup's `type` prop is `HTMLInputTypeAttribute`, which excludes the
// non-input "select" sentinel. Map it to a harmless value when we're going
// to render a `<select>` anyway.
const inputType = type === "select" ? "text" : type;
---

<FormGroup
  label={effectiveLabel}
  name={effectiveName}
  type={inputType}
  isSelect={type === "select"}
  selectOptions={selectOptions}
  isRequired={isRequired}
  autocomplete={effectiveAutocomplete}
  placeholder={placeholder}
/>
