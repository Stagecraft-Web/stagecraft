---
/**
 * Newsletter phone field — child tag of `{% newsletter-signup %}`.
 *
 * The phone-specific block. Defaults `name="phone"`, `label="Phone"`,
 * `autocomplete="tel"`, and `type="tel"` on the input. Optional by default
 * — most newsletter signups don't require a phone number.
 */
import FormGroup from "../../components/FormGroup.astro";
import type { AutocompleteToken } from "../_shared/types";

interface Props {
  name?: string;
  label?: string;
  autocomplete?: AutocompleteToken;
  isRequired?: boolean;
  placeholder?: string;
}

const {
  name = "phone",
  label = "Phone",
  autocomplete = "tel",
  isRequired = false,
  placeholder,
} = Astro.props;
---

<FormGroup
  type="tel"
  name={name}
  label={label}
  autocomplete={autocomplete}
  isRequired={isRequired}
  placeholder={placeholder}
/>
