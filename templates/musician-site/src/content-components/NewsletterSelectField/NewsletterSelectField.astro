---
/**
 * Newsletter select field — child tag of `{% newsletter-signup %}`.
 *
 * Dropdown for things like "How did you hear about us?". Choices are
 * authored as a pipe-separated `options` string (`"Friend|Social|Other"`)
 * — flat string keeps markdoc attributes simple. The empty-state prompt
 * (when not required) defaults to `placeholder` if set, else
 * "Select an option".
 */
import FormGroup from "../../components/FormGroup.astro";
import type { AutocompleteToken } from "../_shared/types";
import { parseFieldOptions } from "./parseFieldOptions";

interface Props {
  name: string;
  label: string;
  options: string;
  autocomplete?: AutocompleteToken;
  isRequired?: boolean;
  placeholder?: string;
}

const {
  name,
  label,
  options,
  autocomplete = "off",
  isRequired = false,
  placeholder,
} = Astro.props;

const selectOptions = parseFieldOptions(options);
---

<FormGroup
  type="select"
  name={name}
  label={label}
  selectOptions={selectOptions}
  autocomplete={autocomplete}
  isRequired={isRequired}
  placeholder={placeholder}
/>
