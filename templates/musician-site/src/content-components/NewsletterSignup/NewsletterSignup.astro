---
/**
 * Newsletter signup form.
 *
 * Renders a `<form action={actionUrl} method="post">` with service-specific
 * field names (Mailchimp's form handler wants `EMAIL`; ConvertKit wants
 * `email_address`; etc.). A small inline `<script>` intercepts submission
 * and fetches with `mode: "no-cors"` — Mailchimp/ConvertKit reject CORS
 * from browser origins, so the response is opaque. We optimistically show
 * the success message on fetch completion. If JS is disabled, the native
 * form still submits (the service handles the confirmation page).
 *
 * Wrapper tag: authors nest `{% newsletter-field %}` children inside this
 * block to add arbitrary extra inputs (first name, referral source, etc.).
 * The email input is always rendered first by this component — it's the
 * mandatory primary field every newsletter provider needs, and its
 * per-service field name is hardcoded here rather than in the child tag.
 *
 * Anti-spam: two honeypot fields.
 *   1. Universal `_gotcha` — hidden off-screen. Checked client-side: if
 *      non-empty, we silently pretend to succeed instead of POSTing.
 *   2. Service-specific (Mailchimp only): a field named starting with
 *      `b_`. Mailchimp's real bot-trap has an audience-specific suffix;
 *      we emit a generic `b_subscribe_honeypot` as a best-effort without
 *      parsing the actionUrl (see schema.ts keystatic description).
 */
import type { NewsletterService } from "./schema";

interface Props {
  service: NewsletterService;
  actionUrl: string;
  title?: string;
  submitLabel?: string;
  successMessage?: string;
}

const {
  service,
  actionUrl,
  title = "Newsletter",
  submitLabel = "Subscribe",
  successMessage = "Thanks for subscribing!",
} = Astro.props;

// Service-specific field name for the primary email input. Keep this object
// exhaustive over `NewsletterService` so adding a new provider to the union
// fails typecheck here first. (Custom child fields bypass this map — the
// author passes the raw provider field name via the `name` attribute.)
const EMAIL_FIELD_NAMES: Record<NewsletterService, string> = {
  mailchimp: "EMAIL",
  convertkit: "email_address",
  buttondown: "email",
  generic: "email",
};

const emailFieldName = EMAIL_FIELD_NAMES[service];

// Unique id per block instance so multiple newsletter-signup blocks on
// one page don't collide on form / status element ids.
const instanceId = `newsletter-signup-${Math.random().toString(36).slice(2, 10)}`;
const formId = `${instanceId}-form`;
const statusId = `${instanceId}-status`;
const emailInputId = `${instanceId}-email`;
---

<div class="newsletter-signup">
  {title && <h3 class="newsletter-signup-title">{title}</h3>}

  <form
    id={formId}
    class="newsletter-signup-form"
    action={actionUrl}
    method="post"
    data-success-message={successMessage}
  >
    <slot />

    <div class="newsletter-signup-group">
      <label for={emailInputId}>Email</label>
      <input
        id={emailInputId}
        type="email"
        name={emailFieldName}
        autocomplete="email"
        required
      />
    </div>

    {/*
      Universal honeypot. Hidden off-screen (not `display:none`, because
      some bots skip display:none inputs; off-screen positioning is the
      convention for screen-reader accessibility + bot baiting).
    */}
    <div class="newsletter-signup-honeypot" aria-hidden="true">
      <label for={`${instanceId}-gotcha`}>Leave this field empty</label>
      <input
        id={`${instanceId}-gotcha`}
        type="text"
        name="_gotcha"
        tabindex="-1"
        autocomplete="off"
      />
    </div>

    {service === "mailchimp" && (
      // Mailchimp's bot-trap convention: a hidden input whose name starts
      // with `b_` and includes an audience-specific suffix. We don't parse
      // the actionUrl, so the suffix is a generic placeholder. See the
      // schema.ts keystatic description for the caveat.
      <div class="newsletter-signup-honeypot" aria-hidden="true">
        <input
          type="text"
          name="b_subscribe_honeypot"
          tabindex="-1"
          autocomplete="off"
          value=""
        />
      </div>
    )}

    <button type="submit" class="newsletter-signup-submit">{submitLabel}</button>

    <div id={statusId} class="newsletter-signup-status" role="status" aria-live="polite"></div>
  </form>
</div>

<script is:inline define:vars={{ formId, statusId }}>
  // Inline — one listener per form instance. The `define:vars` block above
  // scopes `formId` / `statusId` into this script so multiple signup forms
  // on one page stay independent.
  const form = document.getElementById(formId);
  const status = document.getElementById(statusId);
  if (form && status) {
    const submitBtn = form.querySelector('button[type="submit"]');
    const successMessage = form.dataset.successMessage || "Thanks for subscribing!";

    form.addEventListener("submit", async (e) => {
      e.preventDefault();

      const fd = new FormData(form);

      // Honeypot — if filled, a bot likely submitted. Show the success UI
      // without POSTing so we don't tip off the bot.
      const gotcha = fd.get("_gotcha");
      if (typeof gotcha === "string" && gotcha.trim() !== "") {
        status.textContent = successMessage;
        status.classList.add("newsletter-signup-status-success");
        form.reset();
        return;
      }

      if (submitBtn) {
        submitBtn.disabled = true;
      }

      try {
        // `no-cors` — Mailchimp/ConvertKit reject CORS preflight from
        // browser origins, so a normal fetch would fail before the server
        // sees the request. `no-cors` lets the POST through at the cost of
        // an opaque response. We optimistically treat any completion as
        // success; the real confirmation is the user's inbox (double opt-in).
        await fetch(form.action, {
          method: "POST",
          body: fd,
          mode: "no-cors",
        });
      } catch {
        // Even a network error surfaces as success in the no-cors flow —
        // the POST may have gone through and we just can't tell. Prefer
        // the optimistic UX over scaring the user with false negatives.
      }

      status.textContent = successMessage;
      status.classList.add("newsletter-signup-status-success");
      form.reset();

      if (submitBtn) {
        submitBtn.disabled = false;
      }
    });
  }
</script>

<style>
  .newsletter-signup {
    max-width: var(--max-text);
  }

  .newsletter-signup-title {
    margin: 0 0 0.75rem;
    font-family: var(--font-heading);
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-semibold);
    color: var(--color-primary);
  }

  .newsletter-signup-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .newsletter-signup-group {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .newsletter-signup-group label {
    font-weight: var(--font-weight-medium);
    font-size: var(--font-size-sm);
    color: var(--color-text);
  }

  .newsletter-signup-group input {
    width: 100%;
    padding: 0.625rem 0.75rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    font-family: var(--font-body);
    font-size: var(--font-size-base);
    background: var(--color-surface);
    color: var(--color-text);
  }

  .newsletter-signup-group input:focus {
    outline: 2px solid var(--color-secondary);
    outline-offset: 1px;
    border-color: transparent;
  }

  /*
   * Honeypot fields — positioned off-screen rather than `display: none` so
   * they're present in the accessibility tree for bots that skip hidden
   * inputs, but invisible / unreachable for real users.
   */
  .newsletter-signup-honeypot {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .newsletter-signup-submit {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.5rem;
    border: none;
    border-radius: var(--radius);
    background: var(--color-secondary);
    color: var(--color-white);
    font-family: var(--font-body);
    font-weight: var(--font-weight-semibold);
    font-size: var(--font-size-base);
    line-height: 1;
    cursor: pointer;
    transition: opacity 0.15s;
  }

  .newsletter-signup-submit:hover {
    opacity: 0.9;
  }

  .newsletter-signup-submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .newsletter-signup-status {
    font-size: var(--font-size-sm);
    border-radius: var(--radius);
    transition: padding 0.15s;
  }

  .newsletter-signup-status-success {
    color: var(--color-primary);
    background: var(--color-surface);
    padding: 0.75rem 1rem;
    border: 1px solid var(--color-border);
  }
</style>
