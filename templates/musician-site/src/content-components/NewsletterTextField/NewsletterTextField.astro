---
/**
 * Newsletter text field — child tag of `{% newsletter-signup %}`.
 *
 * Generic text input for fields that don't fit the email/phone presets
 * (first/last name, custom metadata, referrer source, etc.). Both `name`
 * and `label` are required at the markdoc layer — there's no obvious
 * default for an arbitrary text field.
 */
import FormGroup from "../../components/FormGroup.astro";
import type { AutocompleteToken } from "../_shared/types";

interface Props {
  name: string;
  label: string;
  autocomplete?: AutocompleteToken;
  isRequired?: boolean;
  placeholder?: string;
}

const {
  name,
  label,
  autocomplete = "off",
  isRequired = false,
  placeholder,
} = Astro.props;
---

<FormGroup
  type="text"
  name={name}
  label={label}
  autocomplete={autocomplete}
  isRequired={isRequired}
  placeholder={placeholder}
/>
