---
// Markdoc block — reads the `photos` collection and delegates rendering to
// the shared PhotoGallery layout component (which stays in src/components/
// because it's also used directly by other pages, not just as a markdoc tag).
import PhotoGalleryLayout from "../../components/PhotoGallery.astro";
import { getCollection } from "astro:content";

const photoEntries = await getCollection("photos");
const photos = photoEntries.map((e) => e.data);
---

{photos.length > 0 && <PhotoGalleryLayout photos={photos} />}
