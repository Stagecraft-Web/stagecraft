---
// Markdoc block — reads the `posts` collection and renders either a card
// grid (default) or a linear row list. Filtering, sorting, and limiting is
// delegated to the pure helper in src/lib/resolve-posts.ts so the logic
// stays unit-testable.
//
// Each card links to the internal `/news/<slug>` page by default, or to
// `post.data.externalUrl` when the author set one (e.g. for off-site press
// pickups). External links open in a new tab.
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import {
  resolvePosts,
  getPostHref,
  isPostExternal,
  type PostsListFilterCategory,
} from "../../lib/resolve-posts";
import type { PostsListLayout } from "./schema";

interface Props {
  limit?: number;
  category?: PostsListFilterCategory;
  layout?: PostsListLayout;
}

const { limit, category = "all", layout = "grid" } = Astro.props;

const entries = await getCollection("posts");
const posts = resolvePosts(entries, { limit, category });

// Parse YYYY-MM-DD as a local-time date so the rendered label matches what
// the author entered. `new Date("2024-09-01")` is parsed as UTC midnight and
// shifts a day earlier in negative-UTC time zones — using the numeric parts
// explicitly avoids that off-by-one.
const formatDate = (iso: string) => {
  const [y, m, d] = iso.split("-").map(Number);
  return new Date(y, m - 1, d).toLocaleDateString(undefined, {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
};
---

{posts.length > 0 && (
  <ul class:list={["posts-list", `posts-list--${layout}`]} role="list">
    {posts.map((post) => {
      const href = getPostHref(post);
      const isExternal = isPostExternal(post);
      return (
        <li class="posts-list-item">
          <a
            class="posts-list-link"
            href={href}
            target={isExternal ? "_blank" : undefined}
            rel={isExternal ? "noopener noreferrer" : undefined}
          >
            {post.data.featuredImage && (
              <div class="posts-list-image">
                <Image
                  src={post.data.featuredImage.src}
                  alt={post.data.featuredImage.alt}
                />
              </div>
            )}
            <div class="posts-list-body">
              <p class="posts-list-category">{post.data.category}</p>
              <h3 class="posts-list-title">{post.data.title}</h3>
              <time class="posts-list-date" datetime={post.data.publishedDate}>
                {formatDate(post.data.publishedDate)}
              </time>
              {post.data.excerpt && (
                <p class="posts-list-excerpt">{post.data.excerpt}</p>
              )}
            </div>
          </a>
        </li>
      );
    })}
  </ul>
)}

<style>
  .posts-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1.5rem;
  }

  .posts-list--grid {
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 280px), 1fr));
  }

  .posts-list--list {
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  .posts-list-item {
    margin: 0;
  }

  .posts-list-link {
    display: flex;
    flex-direction: column;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
    color: inherit;
    text-decoration: none;
    height: 100%;
    transition: transform 150ms ease, box-shadow 150ms ease;
  }

  .posts-list--list .posts-list-link {
    flex-direction: row;
    align-items: stretch;
  }

  .posts-list-link:hover,
  .posts-list-link:focus-visible {
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(0, 0, 0, 0.08);
  }

  .posts-list-image {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--color-border);
  }

  .posts-list--list .posts-list-image {
    width: 180px;
    flex-shrink: 0;
    aspect-ratio: auto;
  }

  .posts-list-image :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .posts-list-body {
    padding: 1rem 1.25rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    flex: 1;
  }

  .posts-list-category {
    margin: 0;
    font-size: var(--font-size-xs);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-secondary);
    font-weight: var(--font-weight-semibold);
  }

  .posts-list-title {
    margin: 0;
    font-size: var(--font-size-lg);
    line-height: 1.3;
  }

  .posts-list-date {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
  }

  .posts-list-excerpt {
    margin: 0.25rem 0 0;
    color: var(--color-text-muted);
    font-size: var(--font-size-sm);
    line-height: 1.5;
  }
</style>
