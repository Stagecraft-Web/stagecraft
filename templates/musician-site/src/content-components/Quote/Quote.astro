---
interface Props {
  /** The quote body. Required. */
  text: string;
  /** Optional attribution rendered as `<cite>` below the quote. */
  attribution?: string;
}

const { text, attribution } = Astro.props;
---

<blockquote class="quote">
  <p class="quote-text">{text}</p>
  {attribution && <cite class="quote-attribution">{attribution}</cite>}
</blockquote>

<style>
  .quote {
    max-width: 45rem;
    margin-block: 2rem;
    padding: 0;
    border: 0;
  }

  .quote-text {
    margin: 0;
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-semibold);
    line-height: 1.4;
    font-style: italic;
    color: var(--color-primary);
  }

  .quote-attribution {
    display: block;
    margin-top: 0.75rem;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-normal);
    font-style: normal;
    color: var(--color-text-muted);
  }

  .quote-attribution::before {
    content: "— ";
  }
</style>
