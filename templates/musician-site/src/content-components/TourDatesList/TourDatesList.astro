---
// Markdoc block — reads the `tourDates` collection and auto-groups entries
// into upcoming and past buckets around today's date (ISO date in the build
// host's local timezone).
//
// Rendering rules (see spec §3.2):
//   - upcoming.length >= 2 → render upcoming-only (ascending).
//   - upcoming.length === 1 → render that show + the most-recent
//     `pastPadding` past shows under a "Recent shows" subheading.
//   - upcoming.length === 0 → render `emptyMessage` + the same padded
//     past shows below.
//
// "Upcoming" = date >= today AND status !== "canceled".
// "Past"     = date < today OR status === "canceled".
// Past shows sort descending (newest first); upcoming ascending (next first).
//
// ISO date strings ("YYYY-MM-DD") sort lexicographically == chronologically,
// so no Date parsing is required for bucketing/ordering.
import { getCollection } from "astro:content";
import Button from "../Button/Button.astro";
import type { TourDate } from "../../lib/schemas";
import { groupTourDates } from "./groupTourDates";

interface Props {
  pastPadding?: number;
  emptyMessage?: string;
}

const {
  pastPadding = 3,
  emptyMessage = "No upcoming shows. Check back soon.",
} = Astro.props;

const tourDateEntries = await getCollection("tourDates");
const allDates: TourDate[] = tourDateEntries.map((e) => e.data);

// Cutoff: today's date in the build host's local timezone, as an ISO
// "YYYY-MM-DD" string. Compared lexicographically against each entry's
// `date` field (also ISO).
const today = new Date().toISOString().slice(0, 10);

const { primary: primaryDates, paddedPast, isEmpty: isEmptyState } =
  groupTourDates(allDates, today, pastPadding);

const hasPrimary = primaryDates.length > 0;
const hasPadded = paddedPast.length > 0;

// Best-effort human-friendly date format. Renders server-side with the
// site's default locale so output is deterministic.
function formatDate(iso: string): { weekday: string; monthDay: string; year: string } {
  // Append a noon-UTC time so the parsed Date doesn't shift across DST/local
  // timezones — the ISO date is the author's intent, not a UTC instant.
  const d = new Date(`${iso}T12:00:00`);
  if (Number.isNaN(d.valueOf())) {
    return { weekday: "", monthDay: iso, year: "" };
  }
  return {
    weekday: d.toLocaleDateString("en-US", { weekday: "short" }),
    monthDay: d.toLocaleDateString("en-US", { month: "short", day: "numeric" }),
    year: d.getFullYear().toString(),
  };
}
---

{hasPrimary && (
  <ul class="tour-dates-list">
    {primaryDates.map((tourDate) => {
      const dateParts = formatDate(tourDate.date);
      const isSoldOut = tourDate.status === "sold_out";
      const isCanceled = tourDate.status === "canceled";
      const isPast = tourDate.status === "past";
      const hasTicketLink = !!tourDate.ticketUrl && tourDate.status === "upcoming";
      return (
        <li class:list={["tour-date", { "is-canceled": isCanceled, "is-past": isPast }]}>
          <div class="tour-date-when">
            <span class="tour-date-weekday">{dateParts.weekday}</span>
            <span class="tour-date-monthday">{dateParts.monthDay}</span>
            <span class="tour-date-year">{dateParts.year}</span>
          </div>
          <div class="tour-date-where">
            <div class="tour-date-venue">{tourDate.venue}</div>
            <div class="tour-date-city">{tourDate.city}</div>
          </div>
          <div class="tour-date-action">
            {hasTicketLink && (
              <Button
                href={tourDate.ticketUrl}
                variant="primary"
                isExternal
                label="Tickets"
              />
            )}
            {isSoldOut && <span class="tour-date-badge is-sold-out">Sold Out</span>}
            {isCanceled && <span class="tour-date-badge is-canceled-badge">Canceled</span>}
            {isPast && <span class="tour-date-badge is-past-badge">Past</span>}
          </div>
        </li>
      );
    })}
  </ul>
)}

{isEmptyState && (
  <p class="tour-dates-empty">{emptyMessage}</p>
)}

{hasPadded && (
  <div class="tour-dates-recent">
    <h3 class="tour-dates-recent-heading">Past shows</h3>
    <ul class="tour-dates-list">
      {paddedPast.map((tourDate) => {
        const dateParts = formatDate(tourDate.date);
        const isSoldOut = tourDate.status === "sold_out";
        const isCanceled = tourDate.status === "canceled";
        // Any past-bucket row renders as "is-past" visually; the explicit
        // `status === "past"` badge only fires when the author set it, but
        // the container gets the dimmed-past styling regardless.
        const isPast = true;
        return (
          <li class:list={["tour-date", { "is-canceled": isCanceled, "is-past": isPast }]}>
            <div class="tour-date-when">
              <span class="tour-date-weekday">{dateParts.weekday}</span>
              <span class="tour-date-monthday">{dateParts.monthDay}</span>
              <span class="tour-date-year">{dateParts.year}</span>
            </div>
            <div class="tour-date-where">
              <div class="tour-date-venue">{tourDate.venue}</div>
              <div class="tour-date-city">{tourDate.city}</div>
            </div>
            <div class="tour-date-action">
              {isSoldOut && <span class="tour-date-badge is-sold-out">Sold Out</span>}
              {isCanceled && <span class="tour-date-badge is-canceled-badge">Canceled</span>}
            </div>
          </li>
        );
      })}
    </ul>
  </div>
)}

<style>
  .tour-dates-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .tour-dates-recent {
    margin-top: 2rem;
  }

  .tour-dates-recent-heading {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 0.75rem;
  }

  .tour-date {
    display: grid;
    grid-template-columns: minmax(5rem, auto) 1fr auto;
    gap: 1.5rem;
    align-items: center;
    padding: 1rem 1.25rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
  }

  .tour-date.is-canceled,
  .tour-date.is-past {
    opacity: 0.65;
  }

  .tour-date.is-canceled .tour-date-venue,
  .tour-date.is-canceled .tour-date-city {
    text-decoration: line-through;
  }

  .tour-date-when {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }

  .tour-date-weekday {
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .tour-date-monthday {
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text);
  }

  .tour-date-year {
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
  }

  .tour-date-venue {
    font-weight: var(--font-weight-semibold);
    color: var(--color-text);
  }

  .tour-date-city {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    margin-top: 0.125rem;
  }

  .tour-date-action {
    display: flex;
    align-items: center;
    justify-content: flex-end;
  }

  .tour-date-badge {
    display: inline-block;
    padding: 0.375rem 0.75rem;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: var(--radius);
    color: var(--color-text-muted);
    background: transparent;
    border: 1px solid var(--color-border);
  }

  .tour-date-badge.is-sold-out {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .tour-dates-empty {
    color: var(--color-text-muted);
    font-style: italic;
  }

  @media (max-width: 600px) {
    .tour-date {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }
    .tour-date-action {
      justify-content: flex-start;
    }
  }
</style>
