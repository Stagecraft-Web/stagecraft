---
// Markdoc block — reads the `tourDates` collection and auto-groups entries
// into upcoming and past buckets around today's date (ISO date in the build
// host's local timezone).
//
// Rendering rules (see spec §3.2):
//   - upcoming.length >= 2 → render upcoming-only (ascending).
//   - upcoming.length === 1 → render that show + the most-recent
//     `pastPadding` past shows under a "Recent shows" subheading.
//   - upcoming.length === 0 → render `emptyMessage` + the same padded
//     past shows below.
//
// "Upcoming" = date >= today AND status !== "canceled".
// "Past"     = date < today OR status === "canceled".
// Past shows sort descending (newest first); upcoming ascending (next first).
//
// ISO date strings ("YYYY-MM-DD") sort lexicographically == chronologically,
// so no Date parsing is required for bucketing/ordering.
//
// Pagination (§3.3): long lists are split into batches of `pageSize` (default
// 10). The renderer emits every row up-front; rows past the first batch
// carry the `hidden` attribute and a small inline script un-hides the next
// batch each time the "Show more" button is clicked. Primary and padded-past
// sections each get their own independent counter on the rare occasion that
// both overflow.
//
// Filter (§3.4): when `categoryFilter` is set on the block, entries are
// narrowed by exact `category` match BEFORE bucketing — so upcoming/past
// counts reflect the filtered subset.
import { getCollection } from "astro:content";
import Button from "../Button/Button.astro";
import type { TourDate } from "../../lib/schemas";
import { groupTourDates } from "./groupTourDates";
import { filterByCategory } from "./filterTourDates";
import { computePageBatches } from "./pagination";

interface Props {
  pastPadding?: number;
  emptyMessage?: string;
  pageSize?: number;
  categoryFilter?: string;
}

const {
  pastPadding = 3,
  emptyMessage = "No upcoming shows. Check back soon.",
  pageSize = 10,
  categoryFilter,
} = Astro.props;

const tourDateEntries = await getCollection("tourDates");
const allDates: TourDate[] = tourDateEntries.map((e) => e.data);

// Cutoff: today's date in the build host's local timezone, as an ISO
// "YYYY-MM-DD" string. Compared lexicographically against each entry's
// `date` field (also ISO).
const today = new Date().toISOString().slice(0, 10);

// Narrow to the requested category FIRST so the upcoming/past bucketing
// only sees relevant rows — otherwise a block scoped to "Winter Tour"
// would still hit the "0 upcoming → pad with past" branch based on other
// series' dates.
const scopedDates = filterByCategory(allDates, categoryFilter);

const { primary: primaryDates, paddedPast, isEmpty: isEmptyState } =
  groupTourDates(scopedDates, today, pastPadding);

const hasPrimary = primaryDates.length > 0;
const hasPadded = paddedPast.length > 0;

// Batch each bucket so we know which rows start visible and how many
// reveal-steps the "Show more" button needs to walk through. `computePageBatches`
// returns `[]` for empty input and `[items]` when everything fits in one
// page — the >1 check is what drives the button's visibility.
const primaryBatches = computePageBatches(primaryDates, pageSize);
const paddedBatches = computePageBatches(paddedPast, pageSize);
const primaryHasOverflow = primaryBatches.length > 1;
const paddedHasOverflow = paddedBatches.length > 1;

// Best-effort human-friendly date format. Renders server-side with the
// site's default locale so output is deterministic.
function formatDate(iso: string): { weekday: string; monthDay: string; year: string } {
  // Append a noon-UTC time so the parsed Date doesn't shift across DST/local
  // timezones — the ISO date is the author's intent, not a UTC instant.
  const d = new Date(`${iso}T12:00:00`);
  if (Number.isNaN(d.valueOf())) {
    return { weekday: "", monthDay: iso, year: "" };
  }
  return {
    weekday: d.toLocaleDateString("en-US", { weekday: "short" }),
    monthDay: d.toLocaleDateString("en-US", { month: "short", day: "numeric" }),
    year: d.getFullYear().toString(),
  };
}

// Clamp pageSize once, server-side, for the reveal script — same clamping
// rule as `computePageBatches` so the two stay in lock-step.
const clampedPageSize = Math.max(1, Math.floor(pageSize));
---

{hasPrimary && (
  <div class="tour-dates-section" data-tour-dates-section data-page-size={clampedPageSize}>
    <ul class="tour-dates-list">
      {primaryDates.map((tourDate, index) => {
        const dateParts = formatDate(tourDate.date);
        const isSoldOut = tourDate.status === "sold_out";
        const isCanceled = tourDate.status === "canceled";
        const isPast = tourDate.status === "past";
        const hasTicketLink = !!tourDate.ticketUrl && tourDate.status === "upcoming";
        const isOverflow = index >= clampedPageSize;
        return (
          <li
            class:list={["tour-date", { "is-canceled": isCanceled, "is-past": isPast }]}
            hidden={isOverflow}
          >
            <div class="tour-date-when">
              <span class="tour-date-weekday">{dateParts.weekday}</span>
              <span class="tour-date-monthday">{dateParts.monthDay}</span>
              <span class="tour-date-year">{dateParts.year}</span>
            </div>
            <div class="tour-date-where">
              <div class="tour-date-venue">{tourDate.venue}</div>
              <div class="tour-date-city">{tourDate.city}</div>
              {tourDate.category && (
                <div class="tour-date-category">{tourDate.category}</div>
              )}
            </div>
            <div class="tour-date-action">
              {hasTicketLink && (
                <Button
                  href={tourDate.ticketUrl}
                  variant="primary"
                  isExternal
                  label="Tickets"
                />
              )}
              {isSoldOut && <span class="tour-date-badge is-sold-out">Sold Out</span>}
              {isCanceled && <span class="tour-date-badge is-canceled-badge">Canceled</span>}
              {isPast && <span class="tour-date-badge is-past-badge">Past</span>}
            </div>
          </li>
        );
      })}
    </ul>
    {primaryHasOverflow && (
      <div class="tour-dates-reveal">
        <button
          type="button"
          class="tour-dates-show-more"
          data-tour-dates-show-more
        >
          Show more
        </button>
        <p
          class="screenreader-only"
          role="status"
          aria-live="polite"
          data-tour-dates-announce
        ></p>
      </div>
    )}
  </div>
)}

{isEmptyState && (
  <p class="tour-dates-empty">{emptyMessage}</p>
)}

{hasPadded && (
  <div class="tour-dates-recent tour-dates-section" data-tour-dates-section data-page-size={clampedPageSize}>
    <h3 class="tour-dates-recent-heading">Recent shows</h3>
    <ul class="tour-dates-list">
      {paddedPast.map((tourDate, index) => {
        const dateParts = formatDate(tourDate.date);
        const isSoldOut = tourDate.status === "sold_out";
        const isCanceled = tourDate.status === "canceled";
        // Any past-bucket row renders as "is-past" visually; the explicit
        // `status === "past"` badge only fires when the author set it, but
        // the container gets the dimmed-past styling regardless.
        const isPast = true;
        const isOverflow = index >= clampedPageSize;
        return (
          <li
            class:list={["tour-date", { "is-canceled": isCanceled, "is-past": isPast }]}
            hidden={isOverflow}
          >
            <div class="tour-date-when">
              <span class="tour-date-weekday">{dateParts.weekday}</span>
              <span class="tour-date-monthday">{dateParts.monthDay}</span>
              <span class="tour-date-year">{dateParts.year}</span>
            </div>
            <div class="tour-date-where">
              <div class="tour-date-venue">{tourDate.venue}</div>
              <div class="tour-date-city">{tourDate.city}</div>
              {tourDate.category && (
                <div class="tour-date-category">{tourDate.category}</div>
              )}
            </div>
            <div class="tour-date-action">
              {isSoldOut && <span class="tour-date-badge is-sold-out">Sold Out</span>}
              {isCanceled && <span class="tour-date-badge is-canceled-badge">Canceled</span>}
              {!isSoldOut && !isCanceled && (
                <span class="tour-date-badge is-past-badge">Past</span>
              )}
            </div>
          </li>
        );
      })}
    </ul>
    {paddedHasOverflow && (
      <div class="tour-dates-reveal">
        <button
          type="button"
          class="tour-dates-show-more"
          data-tour-dates-show-more
        >
          Show more
        </button>
        <p
          class="screenreader-only"
          role="status"
          aria-live="polite"
          data-tour-dates-announce
        ></p>
      </div>
    )}
  </div>
)}

{(primaryHasOverflow || paddedHasOverflow) && (
  <script>
    // Progressive-reveal script. Each `[data-tour-dates-section]` wraps its
    // own `<ul>` + its own "Show more" button + its own live region, so
    // primary and padded-past sections walk their counters independently.
    // No fetching, no routing — just flipping the `hidden` attribute on the
    // next `pageSize` hidden siblings.
    document.querySelectorAll("[data-tour-dates-section]").forEach((section) => {
      const button = section.querySelector("[data-tour-dates-show-more]");
      if (!(button instanceof HTMLButtonElement)) return;
      const announce = section.querySelector("[data-tour-dates-announce]");
      const pageSizeAttr = section.getAttribute("data-page-size");
      const parsed = pageSizeAttr ? parseInt(pageSizeAttr, 10) : 10;
      const pageSize = Number.isFinite(parsed) && parsed > 0 ? parsed : 10;
      button.addEventListener("click", () => {
        const hiddenRows = Array.from(
          section.querySelectorAll<HTMLLIElement>("li.tour-date[hidden]"),
        );
        const revealed = hiddenRows.slice(0, pageSize);
        revealed.forEach((row) => row.removeAttribute("hidden"));
        const stillHidden = hiddenRows.length - revealed.length;
        if (announce) {
          const noun = revealed.length === 1 ? "show" : "shows";
          announce.textContent = `Showing ${revealed.length} more ${noun}.`;
        }
        if (stillHidden === 0) {
          button.setAttribute("hidden", "");
          // Focus the last revealed row so keyboard users land next to the
          // newly visible content rather than on a now-invisible button.
          const lastRevealed = revealed[revealed.length - 1];
          if (lastRevealed) {
            lastRevealed.setAttribute("tabindex", "-1");
            lastRevealed.focus();
          }
        }
      });
    });
  </script>
)}

<style>
  .tour-dates-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .tour-dates-recent {
    margin-top: 2rem;
  }

  .tour-dates-recent-heading {
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0 0 0.75rem;
  }

  .tour-date {
    display: grid;
    grid-template-columns: minmax(5rem, auto) 1fr auto;
    gap: 1.5rem;
    align-items: center;
    padding: 1rem 1.25rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
  }

  .tour-date.is-canceled,
  .tour-date.is-past {
    opacity: 0.65;
  }

  .tour-date.is-canceled .tour-date-venue,
  .tour-date.is-canceled .tour-date-city {
    text-decoration: line-through;
  }

  .tour-date-when {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }

  .tour-date-weekday {
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .tour-date-monthday {
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text);
  }

  .tour-date-year {
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
  }

  .tour-date-venue {
    font-weight: var(--font-weight-semibold);
    color: var(--color-text);
  }

  .tour-date-city {
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    margin-top: 0.125rem;
  }

  .tour-date-category {
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    text-transform: lowercase;
    letter-spacing: 0.05em;
    margin-top: 0.125rem;
  }

  .tour-date-action {
    display: flex;
    align-items: center;
    justify-content: flex-end;
  }

  .tour-date-badge {
    display: inline-block;
    padding: 0.375rem 0.75rem;
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-semibold);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-radius: var(--radius);
    color: var(--color-text-muted);
    background: transparent;
    border: 1px solid var(--color-border);
  }

  .tour-date-badge.is-sold-out {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  .tour-dates-empty {
    color: var(--color-text-muted);
    font-style: italic;
  }

  .tour-dates-reveal {
    margin-top: 1rem;
    display: flex;
    justify-content: center;
  }

  .tour-dates-show-more {
    font: inherit;
    color: var(--color-text);
    background: transparent;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 0.5rem 1.25rem;
    cursor: pointer;
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    letter-spacing: 0.02em;
    transition: border-color 0.15s, color 0.15s;
  }

  .tour-dates-show-more:hover {
    border-color: var(--color-text);
  }

  .tour-dates-show-more:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  @media (max-width: 600px) {
    .tour-date {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }
    .tour-date-action {
      justify-content: flex-start;
    }
  }
</style>
