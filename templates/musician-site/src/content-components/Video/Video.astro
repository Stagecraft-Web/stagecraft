---
// Single-video markdoc block. Resolves the source (collection slug OR direct
// URL) into the same `EmbeddableVideo` shape VideoGallery uses, then renders
// an inline 16:9 iframe.
//
// Why an inline iframe (rather than a thumbnail-that-opens-the-lightbox):
// when an author drops a single video into page content, the expected
// interaction is "play it here", not "click to surface a modal". The
// VideoGallery uses the lightbox because grid items would otherwise need
// six iframes side-by-side (poor performance + visual noise). With one
// iframe the embed is cheap and the autoplay-off default lets the visitor
// decide. Wired to the same toEmbeddable helper so URL parsing stays in
// one place.
import { getEntry } from "astro:content";
import { toEmbeddable, type EmbeddableVideo } from "../VideoGallery/toEmbeddable";
import type { Video } from "../../lib/schemas";
import { validateVideoProps, withoutAutoplay } from "./resolveSource";

interface Props {
  /** Slug of an entry in the `videos` collection. Mutually exclusive with url. */
  slug?: string;
  /** Direct video URL. Mutually exclusive with slug. Requires `type`. */
  url?: string;
  /** Required when `url` is set. */
  type?: "youtube" | "vimeo";
  /** Optional title — used for the iframe's accessible name. */
  title?: string;
  /** Optional caption rendered below the iframe. */
  caption?: string;
}

const { slug, url, type, title, caption } = Astro.props;

// Validate the (slug XOR url) constraint at render time. Markdoc can't
// express this in its attribute schema (no discriminated unions), so a bad
// authoring shape needs to fail loudly here rather than silently rendering
// nothing. Pure validation lives in resolveSource.ts so it's unit-testable.
const resolved = validateVideoProps({ slug, url, type, title });

let video: Video;
if (resolved.mode === "collection") {
  // `getEntry` returns undefined when the slug doesn't match a file. We fail
  // loudly so a typo in the markdoc tag doesn't silently render an empty
  // block — the build error points the author straight at the bad slug.
  const entry = await getEntry("videos", resolved.slug);
  if (!entry) {
    throw new Error(
      `{% video slug="${resolved.slug}" %}: no entry found in the videos collection. ` +
        `Check src/content/collections/videos/ for the matching .yaml file.`,
    );
  }
  video = entry.data;
} else {
  // URL mode — synthesize a Video shape from the inline attrs. Title falls
  // back to "Video" so the iframe always has a non-empty accessible name.
  video = {
    title: resolved.title ?? "Video",
    url: resolved.url,
    type: resolved.type,
    description: undefined,
  };
}

const embeddable: EmbeddableVideo = toEmbeddable(video);

// Strip the `autoplay=1` flag the gallery's lightbox bakes in — for an
// inline embed we want the visitor to press play themselves. `embedUrl` is
// null when the URL couldn't be parsed (e.g. a youtube-typed URL that's
// actually from another host); we surface that as a link-out fallback so
// the content is still reachable.
const inlineEmbedUrl = embeddable.embedUrl
  ? withoutAutoplay(embeddable.embedUrl)
  : null;
---

<figure class="video-block">
  {inlineEmbedUrl ? (
    <div class="video-frame-wrap">
      <iframe
        src={inlineEmbedUrl}
        title={embeddable.title}
        allow="accelerometer; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
        loading="lazy"
        class="video-frame"
      />
    </div>
  ) : (
    <a class="video-fallback" href={embeddable.url} target="_blank" rel="noopener noreferrer">
      Watch video: {embeddable.title}
    </a>
  )}
  {caption && <figcaption class="video-caption">{caption}</figcaption>}
</figure>

<style>
  .video-block {
    margin: 0;
    max-width: 100%;
  }

  .video-frame-wrap {
    position: relative;
    aspect-ratio: 16 / 9;
    width: 100%;
    background: var(--color-surface);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .video-frame {
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }

  .video-fallback {
    display: inline-block;
    padding: 0.75rem 1rem;
    border-radius: var(--radius);
    background: var(--color-surface);
    color: var(--color-text);
    text-decoration: none;
    font-weight: var(--font-weight-semibold);
  }

  .video-fallback:hover,
  .video-fallback:focus-visible {
    text-decoration: underline;
  }

  .video-caption {
    margin-top: 0.5rem;
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    text-align: center;
  }
</style>
