---
// Markdoc block — reads the `videos` collection and renders a responsive
// grid of clickable thumbnails. Clicking a thumbnail opens a modal lightbox
// with the embedded player (YouTube / Vimeo). For "other" video URLs we
// fall back to opening the URL in a new tab, since we can't safely embed
// arbitrary hosts.
import { getCollection } from "astro:content";
import VideoLightbox from "../../components/VideoLightbox";
import { toEmbeddable, type EmbeddableVideo } from "./toEmbeddable";

const videoEntries = await getCollection("videos");
const videos = videoEntries.map((e) => e.data);

// Pre-compute embed URLs and thumbnails server-side so the React lightbox
// receives plain serializable data (no functions, no Astro helpers).
const embeddable: EmbeddableVideo[] = videos.map((v) => toEmbeddable(v));
---

{embeddable.length > 0 && (
  <div class="video-gallery-grid">
    {embeddable.map((video, i) => (
      <button
        class="video-gallery-item"
        data-video-index={i}
        data-video-embeddable={video.isEmbeddable ? "true" : "false"}
        data-video-url={video.url}
        aria-label={`Play ${video.title}`}
      >
        <div class="video-thumb">
          {video.thumbnailUrl ? (
            <img src={video.thumbnailUrl} alt="" loading="lazy" />
          ) : (
            <div class="video-thumb-placeholder" aria-hidden="true">
              <svg
                width="48"
                height="48"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <polygon points="6 4 20 12 6 20 6 4" />
              </svg>
            </div>
          )}
          <span class="video-play-icon" aria-hidden="true">
            <svg width="56" height="56" viewBox="0 0 24 24" fill="currentColor">
              <circle cx="12" cy="12" r="11" fill="rgba(0,0,0,0.55)" />
              <polygon points="10 8 16 12 10 16 10 8" fill="white" />
            </svg>
          </span>
        </div>
        <span class="video-gallery-title">{video.title}</span>
        {video.description && (
          <span class="video-gallery-description">{video.description}</span>
        )}
      </button>
    ))}
  </div>
)}

<VideoLightbox client:only="react" videos={embeddable} />

<script>
  document.querySelectorAll<HTMLButtonElement>("[data-video-index]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const isEmbeddable = btn.dataset.videoEmbeddable === "true";
      const url = btn.dataset.videoUrl;
      if (!isEmbeddable && url) {
        window.open(url, "_blank", "noopener,noreferrer");
        return;
      }
      const index = Number(btn.dataset.videoIndex);
      window.dispatchEvent(
        new CustomEvent("open-video-lightbox", { detail: { index } }),
      );
    });
  });
</script>

<style>
  .video-gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 320px), 1fr));
    gap: 1.5rem;
  }

  .video-gallery-item {
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    border-radius: var(--radius);
    overflow: hidden;
    text-align: left;
    color: inherit;
    font: inherit;
    display: flex;
    flex-direction: column;
  }

  .video-thumb {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--color-surface);
    border-radius: var(--radius);
  }

  .video-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 200ms ease;
  }

  .video-thumb-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-text-muted);
    background: var(--color-surface);
  }

  .video-play-icon {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    opacity: 0.9;
    transition: opacity 200ms ease;
  }

  .video-gallery-item:hover .video-thumb img,
  .video-gallery-item:focus-visible .video-thumb img {
    transform: scale(1.03);
  }

  .video-gallery-item:hover .video-play-icon,
  .video-gallery-item:focus-visible .video-play-icon {
    opacity: 1;
  }

  .video-gallery-title {
    display: block;
    margin-top: 0.5rem;
    font-size: var(--font-size-base);
    font-weight: var(--font-weight-semibold);
    color: var(--color-text);
  }

  .video-gallery-description {
    display: block;
    margin-top: 0.25rem;
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
  }
</style>
