---
import "../styles/global.css";
import { Image } from "astro:assets";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { AppearanceSidebar } from "../components/appearance-sidebar/AppearanceSidebar";
import type { SidebarConfig } from "../components/appearance-sidebar/types";
import { getSiteConfig, getTheme, getAppearance } from "../lib/content";
import { resolveImage } from "../lib/resolve-image";
import {
  appearanceToFontRequests,
  buildGoogleFontsUrl,
  buildFontStack,
} from "../lib/google-fonts";
import {
  pageBackgroundOverlaySchema,
  type PageBackgroundOverlay,
} from "../lib/schemas";

interface Props {
  title?: string;
  description?: string;
  /** When true, hide the site header and footer. Used for splash / landing
   *  pages that display a full-bleed hero and a single "enter site" link.
   *  Splash pages also skip the page-background plumbing — they render their
   *  own full-bleed imagery via FullscreenSection. */
  isSplashPage?: boolean;
  /** Per-page override for the site-level footer toggle. Undefined means
   *  "inherit site-level"; explicit true/false wins for this page only. */
  isFooterHidden?: boolean;
  /** Per-page background image override. When absent, BaseLayout falls back
   *  to the site-wide `pageBackground` from site.json. When set, replaces the
   *  site-level default for this page only.
   *
   *  `src` is a relative path string (not an Astro ImageMetadata object) —
   *  resolveImage() handles the path → optimised metadata lookup so the
   *  site-wide (site.json) and per-page (frontmatter) cases flow through
   *  the same resolver. */
  pageBackground?: { src: string; alt: string };
  /** Per-page overlay override. Same inheritance rules as `pageBackground`.
   *  Overlay defaults (black @ 0.3) apply when individual fields are absent. */
  pageBackgroundOverlay?: Partial<PageBackgroundOverlay>;
}

const site = getSiteConfig();
const theme = getTheme();
const appearance = getAppearance();
const {
  title,
  description,
  isSplashPage = false,
  isFooterHidden,
  pageBackground: pageBackgroundProp,
  pageBackgroundOverlay: pageBackgroundOverlayProp,
} = Astro.props;
const pageTitle = title ? `${title} — ${site.artistName}` : site.siteTitle;
const pageDescription = description ?? site.siteDescription;

// Footer visibility: splash pages never render the footer. Otherwise, a
// page-level explicit value wins; unset falls through to the site-level
// default. `??` handles the "unset" case (undefined) without ever
// collapsing an explicit `false` page override into site's value.
const isFooterRendered = !isSplashPage && !(isFooterHidden ?? site.isFooterHidden);

// Resolve the favicon. If the author uploaded one and we can locate the
// asset in src/assets/**, use its optimised URL; otherwise fall back to the
// default SVG in public/favicons/. Infer the MIME type from the extension.
const faviconImage = site.favicon ? resolveImage(site.favicon) : undefined;
const faviconHref = faviconImage?.src ?? "/favicons/favicon.svg";
const faviconExt = faviconHref.split("?")[0].split(".").pop()?.toLowerCase() ?? "svg";
const faviconType =
  faviconExt === "svg"
    ? "image/svg+xml"
    : faviconExt === "png"
      ? "image/png"
      : faviconExt === "jpg" || faviconExt === "jpeg"
        ? "image/jpeg"
        : undefined;

// -----------------------------------------------------------------
// Page background resolution
//
// Per-page frontmatter overrides the site-wide default. Splash pages skip
// the background layer entirely — they render their own full-bleed imagery
// via FullscreenSection and the overlap would produce a muddy double-tint.
//
// The overlay is normalised through pageBackgroundOverlaySchema so the
// admin-editable empty object (`{}` / partial fields) falls back to the
// spec's default of black @ 30%. Colors flow through CSS custom properties
// so nothing is hardcoded in the stylesheet below.
// -----------------------------------------------------------------
const effectiveBackground = !isSplashPage
  ? (pageBackgroundProp ?? site.pageBackground)
  : undefined;
const resolvedBackground = effectiveBackground
  ? resolveImage(effectiveBackground.src)
  : undefined;
const hasBackground = Boolean(effectiveBackground && resolvedBackground);

const overlayInput = !isSplashPage
  ? (pageBackgroundOverlayProp ?? site.pageBackgroundOverlay ?? {})
  : {};
const overlay = pageBackgroundOverlaySchema.parse(overlayInput);

const colorMode = theme.colorMode ?? "light";

// Build the Google Fonts stylesheet URL with only the exact weights that
// will actually be used (keeps page weight small). When mode === "single"
// or both families happen to match, this collapses into a single request.
const fontsUrl = buildGoogleFontsUrl(appearanceToFontRequests(appearance));

// Derived font stacks used in the CSS-variable injection below.
const bodyStack = buildFontStack(
  appearance.typography.primary.family,
  appearance.typography.primary.category,
);
const headingStack =
  appearance.typography.mode === "split" && appearance.typography.heading
    ? buildFontStack(
        appearance.typography.heading.family,
        appearance.typography.heading.category,
      )
    : bodyStack;

const { colors, typography } = appearance;

// Configuration the in-page sidebar needs on mount. Read from env at build
// time and passed as plain props so the client bundle doesn't need to query
// anything on startup.
//
// `saveMode` is the combined signal the sidebar branches on:
//   - "github-graphql" → Keystatic is in GitHub mode; sidebar commits via
//                        GitHub GraphQL using the user's OAuth cookie.
//                        Works in both dev and prod.
//   - "local-api"      → Dev build with Keystatic in local mode; sidebar
//                        POSTs to /api/stagecraft/appearance which writes
//                        appearance.json to disk. Dev only — the API route
//                        404s in production builds.
//   - "disabled"       → Prod build with local storage (invalid combo;
//                        writes would be lost). Sidebar hides itself.
const storageMode = import.meta.env.PUBLIC_KEYSTATIC_STORAGE === "github" ? "github" : "local";
const saveMode: SidebarConfig["saveMode"] =
  storageMode === "github"
    ? "github-graphql"
    : import.meta.env.DEV
      ? "local-api"
      : "disabled";

const sidebarConfig: SidebarConfig = {
  repo: import.meta.env.PUBLIC_KEYSTATIC_REPO ?? "owner/repo",
  storageMode,
  saveMode,
  appearancePath: "src/content/config/appearance.json",
};
---

<!doctype html>
<html lang="en" data-color-mode={colorMode}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={pageDescription} />
    <title>{pageTitle}</title>
    <link rel="icon" type={faviconType} href={faviconHref} />
    <link rel="apple-touch-icon" href={faviconHref} />

    {/* Google Fonts — preconnect then fetch. Only the exact weights
        in use (see appearance.json → typography.weights) are requested. */}
    {fontsUrl && (
      <>
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link rel="stylesheet" href={fontsUrl} />
      </>
    )}

    {/* Appearance CSS variables — override the defaults in global.css.
        Colors + font stacks come from appearance.json (editable in Keystatic). */}
    <style
      is:inline
      set:html={`:root {
        --color-primary: ${colors.primary};
        --color-secondary: ${colors.secondary};
        --color-accent: ${colors.accent};
        --color-link: ${colors.linkColor};
        --color-bg: ${colors.background};
        --color-surface: ${colors.surface};
        --color-text: ${colors.text};
        --color-text-muted: ${colors.textMuted};
        --color-border: ${colors.border};

        --font-body: ${bodyStack};
        --font-heading: ${headingStack};

        --font-weight-body: ${typography.weights.body};
        --font-weight-body-bold: ${typography.weights.bodyBold};
        --font-weight-h1: ${typography.weights.h1};
        --font-weight-h2: ${typography.weights.h2};
        --font-weight-h3: ${typography.weights.h3};
        --font-weight-h4: ${typography.weights.h4};
        --font-weight-h5: ${typography.weights.h5};
        --font-weight-h6: ${typography.weights.h6};

        --page-bg-overlay-color: ${overlay.color};
        --page-bg-overlay-opacity: ${overlay.opacity};
      }`}
    />

    {/* Inline script to set data-theme before first paint, preventing flash */}
    <script is:inline define:vars={{ colorMode }}>
      (function() {
        if (colorMode === "dark") {
          document.documentElement.setAttribute("data-theme", "dark");
        } else if (colorMode === "light") {
          // Respect viewer's OS preference
          if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
            document.documentElement.setAttribute("data-theme", "dark");
          }
        }
      })();
    </script>
  </head>
  <body class:list={[{ "is-splash-page": isSplashPage, "has-page-background": hasBackground }]}>
    {hasBackground && effectiveBackground && resolvedBackground && (
      <div class="page-background" aria-hidden="true">
        <Image
          src={resolvedBackground}
          alt={effectiveBackground.alt}
          class="page-background-image"
          widths={[640, 1280, 1920, 2560]}
          sizes="100vw"
          loading="eager"
        />
        <div class="page-background-overlay"></div>
      </div>
    )}
    {!isSplashPage && <Header />}
    <main id="main-content">
      <slot />
    </main>
    {isFooterRendered && <Footer />}

    {/* Stagecraft Appearance sidebar — included whenever it has a viable
        save path (GitHub in prod, local API in dev). Hidden in the
        "disabled" case (prod + local storage). In GitHub mode the sidebar
        itself gates on the Keystatic auth cookie before rendering anything
        more than a "Sign in to edit" link. */}
    {sidebarConfig.saveMode !== "disabled" && (
      <AppearanceSidebar
        client:only="react"
        initialState={appearance}
        config={sidebarConfig}
      />
    )}

    <style>
      /* Default page container — every page gets sensible horizontal margins
         and a max-width. Full-bleed children (e.g. FullscreenSection) use a
         breakout pattern to escape these bounds. */
      main {
        width: 100%;
        max-width: var(--max-content);
        margin-inline: auto;
        padding-inline: 1.5rem;
        padding-block: var(--page-pad-y);
      }

      /* Splash pages render without header/footer. Drop main's padding and
         max-width so a FullscreenSection (or similar full-bleed content)
         fills the viewport edge-to-edge without needing the breakout hack. */
      body.is-splash-page main {
        max-width: none;
        padding: 0;
      }

      /* -------------------------------------------------------------------
         Page background layer
         -------------------------------------------------------------------
         Fixed-position layer anchored behind all page content. The image
         stays put while content scrolls over it (classic parallax-lite
         effect); the overlay sits above the image but below content to
         tint the photo without tinting the text.

         z-index ordering:
           -2  .page-background (image wrapper)
           -1  .page-background-overlay (tint)
            0  body content (header/main/footer)

         Color + opacity of the tint are thread-through CSS variables set
         in the inline :root block above — never hardcoded here. */
      .page-background {
        position: fixed;
        inset: 0;
        z-index: -2;
        overflow: hidden;
        pointer-events: none;
      }

      .page-background-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
        display: block;
      }

      .page-background-overlay {
        position: absolute;
        inset: 0;
        background: var(--page-bg-overlay-color);
        opacity: var(--page-bg-overlay-opacity);
        z-index: 1;
      }

      /* When a background is in play, the body surface must be transparent
         so the fixed background shows through. Without this, the body's
         default --color-bg would paint over the image entirely. */
      body.has-page-background {
        background: transparent;
      }
    </style>
    {colorMode === "light" && (
      <script is:inline>
        // Listen for OS theme changes (only in light mode — dark mode is always dark)
        window.matchMedia("(prefers-color-scheme: dark)").addEventListener("change", function(e) {
          document.documentElement.setAttribute("data-theme", e.matches ? "dark" : "light");
        });
      </script>
    )}
  </body>
</html>
