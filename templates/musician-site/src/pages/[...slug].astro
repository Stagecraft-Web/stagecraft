---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const pages = await getCollection("pages");

  // When a page is marked as a splash, it takes over `/` and the regular
  // home page (if any) auto-moves to `/home`. Only one splash may exist.
  const splashes = pages.filter((p) => p.data.isSplashPage);
  if (splashes.length > 1) {
    throw new Error(
      `Only one page can be marked as a splash page. Found ${splashes.length}: ` +
        splashes.map((p) => p.id).join(", ") +
        `. Uncheck "Splash page" on all but one.`,
    );
  }
  const hasSplash = splashes.length === 1;

  return pages.map((p) => {
    // The splash always lives at `/`, regardless of its file name.
    if (p.data.isSplashPage) {
      return { params: { slug: undefined }, props: { entry: p } };
    }
    // The page named "home" takes `/` only when no splash displaces it.
    // If a splash exists, home moves to `/home`.
    if (p.id === "home") {
      return {
        params: { slug: hasSplash ? "home" : undefined },
        props: { entry: p },
      };
    }
    return { params: { slug: p.id }, props: { entry: p } };
  });
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout
  title={entry.data.title}
  isSplashPage={entry.data.isSplashPage}
  isFooterHidden={entry.data.isFooterHidden}
>
  <Content />
</BaseLayout>
