---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import ContactForm from "../components/ContactForm.astro";
import { getEntry, render } from "astro:content";

const contact = await getEntry("pages", "contact");
if (!contact) throw new Error("Missing contact page content");
const { Content } = await render(contact);
---

<BaseLayout title="Contact">
  <PageHeader headline={contact.data.headline} />
  <section class="section">
    <div class="container">
      <div class="prose" style="margin-bottom: 2rem;">
        <Content />
      </div>
      <ContactForm />
    </div>
  </section>
</BaseLayout>
