---
export const prerender = true;

import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import { parseFrontmatter, parseBody } from "../lib/markdown";

// @ts-ignore - markdown import
import homeContent from "../content/pages/home.md?raw";

const frontmatter = parseFrontmatter(homeContent);
const paragraphs = parseBody(homeContent);
const body = paragraphs.join("\n\n");
---

<BaseLayout>
  <Hero
    headline={frontmatter.headline || "Artist Name"}
    subheadline={frontmatter.subheadline}
    ctaText={frontmatter.ctaText}
    ctaLink={frontmatter.ctaLink}
  />
  {body && (
    <section class="section">
      <div class="container">
        <div class="prose">
          <p>{body}</p>
        </div>
      </div>
    </section>
  )}
</BaseLayout>
