---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import ReleaseCard from "../components/ReleaseCard.astro";
import { getEntry, getCollection, render } from "astro:content";

const music = await getEntry("pages", "music");
if (!music) throw new Error("Missing music page content");
const { Content } = await render(music);

const releaseEntries = await getCollection("releases");
const releases = releaseEntries.map((e) => e.data);
---

<BaseLayout title="Music">
  <PageHeader headline={music.data.headline} />
  <section class="section">
    <div class="container">
      <div class="prose" style="margin-bottom: 2rem;">
        <Content />
      </div>
      <div class="grid grid-2">
        {releases.map((release) => (
          <ReleaseCard release={release} />
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
