---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import PhotoGallery from "../components/PhotoGallery";
import { parseFrontmatter } from "../lib/markdown";
import type { Photo } from "../lib/schemas";

// @ts-ignore - markdown import
import photosContent from "../content/pages/photos.md?raw";

const frontmatter = parseFrontmatter(photosContent);

const photoFiles = import.meta.glob("../content/collections/photos/*.json", { eager: true });
const photoSets: Photo[][] = Object.values(photoFiles).map((mod: any) => mod.default);
const photos: Photo[] = photoSets.flat();
---

<BaseLayout title="Photos">
  <PageHeader headline={frontmatter.headline || "Photos"} />
  <section class="section">
    <div class="container">
      <PhotoGallery photos={photos} client:load />
    </div>
  </section>
</BaseLayout>
