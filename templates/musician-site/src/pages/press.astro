---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import Button from "../components/Button.astro";
import { getEntry, getCollection, render } from "astro:content";

const press = await getEntry("pressPage", "press");
if (!press) throw new Error("Missing press page content");
const { Content } = await render(press);

const quoteEntries = await getCollection("pressQuotes");
const quotes = quoteEntries.map((e) => e.data);
---

<BaseLayout title="Press">
  <PageHeader headline={press.data.headline} />
  <section class="section">
    <div class="container">
      <div class="prose" style="margin-bottom: 2rem;">
        <Content />
      </div>

      {press.data.epkDownload && (
        <div style="margin-bottom: 2rem;">
          <Button href={press.data.epkDownload} variant="outline">
            Download EPK
          </Button>
        </div>
      )}

      {quotes.length > 0 && (
        <div class="quotes">
          <h2>{press.data.reviewsHeadline || "Reviews & Press"}</h2>
          <div class="quote-list">
            {quotes.map((q) => (
              <blockquote class="quote-card">
                <p>"{q.quote}"</p>
                <footer>
                  {q.url ? (
                    <a href={q.url} target="_blank" rel="noopener noreferrer">{q.source}</a>
                  ) : (
                    <span>{q.source}</span>
                  )}
                </footer>
              </blockquote>
            ))}
          </div>
        </div>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .quote-list {
    display: grid;
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  .quote-card {
    background: var(--color-surface);
    border-left: 4px solid var(--color-secondary);
    padding: 1.5rem;
    border-radius: var(--radius);
  }

  .quote-card p {
    font-size: var(--font-size-lg);
    font-style: italic;
    line-height: 1.6;
  }

  .quote-card footer {
    margin-top: 0.75rem;
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
  }
</style>
